  "currentHTML": "```html\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>Catalyst — Company Management SaaS</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js\"></script>\n  <script src=\"/forge.js\"></script>\n  <script>window.__flashNavEnabled=true;</script>\n  <script src=\"/flash-nav.js\"></script>\n  <style>\n    html {\n      scroll-behavior: smooth;\n    }\n    .gradient-text {\n      background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n    }\n    .hero-glow {\n      box-shadow: 0 0 60px rgba(59, 130, 246, 0.3), inset 0 0 60px rgba(59, 130, 246, 0.1);\n    }\n    .card-hover {\n      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n    .card-hover:hover {\n      transform: translateY(-8px);\n      box-shadow: 0 20px 40px rgba(59, 130, 246, 0.2);\n    }\n  </style>\n</head>\n<body class=\"bg-neutral-950 text-neutral-100 overflow-x-hidden\">\n  <!-- Navigation -->\n  <nav class=\"fixed top-0 w-full max-w-full z-50 border-b border-neutral-800 bg-neutral-950/80 backdrop-blur-md\">\n    <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16\">\n      <div class=\"flex items-center gap-2\">\n        <div class=\"w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center font-bold text-white\">C</div>\n        <span class=\"font-bold text-lg text-neutral-100\">Catalyst</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8\">\n        <a href=\"#features\" class=\"text-neutral-400 hover:text-neutral-100 transition-colors\">Features</a>\n        <a href=\"#pricing\" class=\"text-neutral-400 hover:text-neutral-100 transition-colors\">Pricing</a>\n        <a href=\"#testimonials\" class=\"text-neutral-400 hover:text-neutral-100 transition-colors\">Testimonials</a>\n      </div>\n      <button class=\"bg-blue-600 hover:bg-blue-500 text-white px-6 py-2 rounded-lg font-semibold transition-colors\">Sign In</button>\n    </div>\n  </nav>\n\n  <!-- Hero Section -->\n  <section id=\"hero\" class=\"pt-32 pb-20 px-4 sm:px-6 lg:px-8 w-full max-w-full\">\n    <div class=\"max-w-7xl mx-auto\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 items-center\">\n        <div>\n          <h1 class=\"text-5xl md:text-6xl font-bold mb-6 leading-tight\">\n            <span class=\"gradient-text\">Manage your company</span> like never before\n          </h1>\n          <p class=\"text-xl text-neutral-400 mb-8 leading-relaxed\">\n            Catalyst unifies teams, projects, and workflows. From hiring to operations, everything flows seamlessly in one intelligent platform.\n          </p>\n          <div class=\"flex flex-col sm:flex-row gap-4\">\n            <button class=\"bg-blue-600 hover:bg-blue-500 text-white px-8 py-4 rounded-lg font-semibold text-lg transition-colors\">\n              Start Free Trial\n            </button>\n            <button class=\"border border-neutral-700 hover:border-neutral-600 text-neutral-100 px-8 py-4 rounded-lg font-semibold text-lg transition-colors\">\n              Watch Demo\n            </button>\n          </div>\n          <p class=\"text-sm text-neutral-500 mt-6\">✓ No credit card required • ✓ 14-day free trial • ✓ Cancel anytime</p>\n        </div>\n        <div class=\"relative h-96 md:h-[500px] hero-glow rounded-2xl border border-neutral-800 bg-gradient-to-br from-blue-900/20 to-neutral-900 flex items-center justify-center overflow-hidden\">\n          <div class=\"absolute inset-0 bg-gradient-to-br from-blue-500/10 via-transparent to-purple-500/10\"></div>\n          <div class=\"relative z-10 text-center\">\n            <i data-lucide=\"activity-square\" class=\"w-24 h-24 text-blue-500 mx-auto mb-4 opacity-50\"></i>\n            <p class=\"text-neutral-400\">Dashboard Preview</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Features Section -->\n  <section id=\"features\" class=\"py-20 px-4 sm:px-6 lg:px-8 w-full max-w-full bg-neutral-900/50 border-t border-neutral-800\">\n    <div class=\"max-w-7xl mx-auto\">\n      <div class=\"text-center mb-16\">\n        <h2 class=\"text-4xl md:text-5xl font-bold mb-4\">Powerful features built for teams</h2>\n        <p class=\"text-xl text-neutral-400 max-w-2xl mx-auto\">Everything you need to run your company operations in one place</p>\n      </div>\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n        <!-- Feature Card 1 -->\n        <div class=\"card-hover bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-600/50\">\n          <div class=\"w-12 h-12 bg-blue-600/20 rounded-lg flex items-center justify-center mb-4\">\n            <i data-lucide=\"users\" class=\"w-6 h-6 text-blue-500\"></i>\n          </div>\n          <h3 class=\"text-lg font-bold mb-2\">Team Management</h3>\n          <p class=\"text-neutral-400\">Organize teams, manage permissions, and collaborate seamlessly across departments</p>\n        </div>\n\n        <!-- Feature Card 2 -->\n        <div class=\"card-hover bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-600/50\">\n          <div class=\"w-12 h-12 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4\">\n            <i data-lucide=\"project\" class=\"w-6 h-6 text-purple-500\"></i>\n          </div>\n          <h3 class=\"text-lg font-bold mb-2\">Project Tracking</h3>\n          <p class=\"text-neutral-400\">Real-time project visibility, milestones, and progress tracking with smart alerts</p>\n        </div>\n\n        <!-- Feature Card 3 -->\n        <div class=\"card-hover bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-600/50\">\n     