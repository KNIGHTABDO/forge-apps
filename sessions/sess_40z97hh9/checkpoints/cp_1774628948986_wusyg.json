nk-level encryption, SSO, 2FA, and compliance with GDPR, SOC2, and HIPAA standards</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Pricing Section -->\n  <section id=\"pricing\" class=\"py-20 px-4 sm:px-6 lg:px-8 w-full max-w-full\">\n    <div class=\"max-w-7xl mx-auto\">\n      <div class=\"text-center mb-16\">\n        <h2 class=\"text-4xl md:text-5xl font-bold mb-4\">Simple, transparent pricing</h2>\n        <p class=\"text-xl text-neutral-400\">Choose the perfect plan for your team</p>\n      </div>\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n        <!-- Starter Plan -->\n        <div class=\"bg-neutral-900 border border-neutral-800 rounded-xl p-8\">\n          <h3 class=\"text-2xl font-bold mb-2\">Starter</h3>\n          <p class=\"text-neutral-400 mb-6\">Perfect for small teams</p>\n          <div class=\"mb-6\">\n            <span class=\"text-5xl font-bold\">$29</span>\n            <span class=\"text-neutral-400\">/month</span>\n          </div>\n          <button class=\"w-full bg-neutral-800 hover:bg-neutral-700 text-white py-3 rounded-lg font-semibold transition-colors mb-6\">\n            Get Started\n          </button>\n          <ul class=\"space-y-3\">\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              Up to 10 team members\n            </li>\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              Basic analytics\n            </li>\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              Project management\n            </li>\n            <li class=\"flex items-center gap-2 text-neutral-400\">\n              <i data-lucide=\"x\" class=\"w-5 h-5 text-neutral-600\"></i>\n              API access\n            </li>\n          </ul>\n        </div>\n\n        <!-- Professional Plan -->\n        <div class=\"bg-neutral-900 border border-blue-600/50 rounded-xl p-8 ring-1 ring-blue-600/30 transform md:scale-105 md:z-10\">\n          <div class=\"bg-blue-600/20 text-blue-400 text-xs font-bold px-3 py-1 rounded-full w-fit mb-4\">MOST POPULAR</div>\n          <h3 class=\"text-2xl font-bold mb-2\">Professional</h3>\n          <p class=\"text-neutral-400 mb-6\">For growing companies</p>\n          <div class=\"mb-6\">\n            <span class=\"text-5xl font-bold\">$79</span>\n            <span class=\"text-neutral-400\">/month</span>\n          </div>\n          <button class=\"w-full bg-blue-600 hover:bg-blue-500 text-white py-3 rounded-lg font-semibold transition-colors mb-6\">\n            Get Started\n          </button>\n          <ul class=\"space-y-3\">\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              Up to 50 team members\n            </li>\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              Advanced analytics\n            </li>\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              Automation workflows\n            </li>\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              API access\n            </li>\n          </ul>\n        </div>\n\n        <!-- Enterprise Plan -->\n        <div class=\"bg-neutral-900 border border-neutral-800 rounded-xl p-8\">\n          <h3 class=\"text-2xl font-bold mb-2\">Enterprise</h3>\n          <p class=\"text-neutral-400 mb-6\">For large organizations</p>\n          <div class=\"mb-6\">\n            <span class=\"text-5xl font-bold\">Custom</span>\n          </div>\n          <button class=\"w-full bg-neutral-800 hover:bg-neutral-700 text-white py-3 rounded-lg font-semibold transition-colors mb-6\">\n            Contact Sales\n          </button>\n          <ul class=\"space-y-3\">\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              Unlimited team members\n            </li>\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              Custom integrations\n            </li>\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              Dedicated support\n            </li>\n            <li class=\"flex items-center gap-2 text-neutral-300\">\n              <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500\"></i>\n              SLA guarantees\n            </li>\n          </ul>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Testimonials Section -->\n  <section id=\"testimonials\" class=\"py-20 px-4 sm:px-6 lg:px-8 w-full max-w-full bg-neutral-900/50 border-t border-neutral-800\">\n    <div class=\"max-w-7xl mx-auto\">\n      <div class=\"text-center mb-16\">\n        <h2 class=\"text-4xl md:text-5xl font-bold mb-4\">Loved by teams everywhere</h2>\n        <p class=\"text-xl text-neutral-400\">Join hundreds of companies transforming their operations</p>\n      </div>\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n        <!-- Testimonial 1 -->\n        <div class=\"bg-neutral-900 border border-neutral-800 rounded-xl p-6\">\n          <div class=\"flex gap-1 mb-4\">\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n          </div>\n          <p class=\"text-neutral-300 mb-4\">\"Catalyst transformed how our team collaborates. We've cut project planning time by 40% and team satisfaction has never been higher.\"</p>\n          <div class=\"flex items-center gap-3\">\n            <div class=\"w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full\"></div>\n            <div>\n              <p class=\"font-semibold\">Sarah Chen</p>\n              <p class=\"text-sm text-neutral-400\">CEO, TechVenture Co</p>\n            </div>\n          </div>\n        </div>\n\n        <!-- Testimonial 2 -->\n        <div class=\"bg-neutral-900 border border-neutral-800 rounded-xl p-6\">\n          <div class=\"flex gap-1 mb-4\">\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n          </div>\n          <p class=\"text-neutral-300 mb-4\">\"The analytics dashboard gives us real-time visibility into every project. We're making smarter decisions faster than ever before.\"</p>\n          <div class=\"flex items-center gap-3\">\n            <div class=\"w-10 h-10 bg-gradient-to-br from-green-500 to-cyan-600 rounded-full\"></div>\n            <div>\n              <p class=\"font-semibold\">Marcus Rodriguez</p>\n              <p class=\"text-sm text-neutral-400\">Operations Director, BuildCorp</p>\n            </div>\n          </div>\n        </div>\n\n        <!-- Testimonial 3 -->\n        <div class=\"bg-neutral-900 border border-neutral-800 rounded-xl p-6\">\n          <div class=\"flex gap-1 mb-4\">\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-yellow-400 fill-current\"></i>\n          </div>\n          <p class=\"text-neutral-300 mb-4\">\"Implementation was seamless and their support team is incredible. Catalyst has become central to our entire operation in just weeks.\"</p>\n          <div class=\"flex items-center gap-3\">\n            <div class=\"w-10 h-10 bg-gradient-to-br from-pink-500 to-orange-600 rounded-full\"></div>\n            <div>\n              <p class=\"font-semibold\">Elena Volkov</p>\n              <p class=\"text-sm text-neutral-400\">Founder, Design Studios LLC</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Blog Section -->\n  <section id=\"blog\" class=\"py-20 px-4 sm:px-6 lg:px-8 w-full max-w-full bg-neutral-900/50 border-t border-neutral-800\">\n    <div class=\"max-w-7xl mx-auto\">\n      <div class=\"text-center mb-16\">\n        <h2 class=\"text-4xl md:text-5xl font-bold mb-4\">Latest from the blog</h2>\n        <p class=\"text-xl text-neutral-400\">Insights, updates, and best practices for modern teams</p>\n      </div>\n\n      <!-- Featured Article -->\n      <div class=\"mb-16\">\n        <div class=\"bg-gradient-to-r from-blue-600/20 to-purple-600/20 border border-blue-600/30 rounded-2xl overflow-hidden\">\n          <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-8 p-8 md:p-12\">\n            <div class=\"flex flex-col justify-center\">\n              <div class=\"flex items-center gap-2 mb-4\">\n                <span class=\"bg-blue-600/30 text-blue-400 text-xs font-bold px-3 py-1 rounded-full\">FEATURED</span>\n                <span class=\"text-neutral-400 text-sm\">5 min read</span>\n              </div>\n              <h3 class=\"text-3xl md:text-4xl font-bold mb-4 leading-tight\">The Future of Team Management: 5 Trends Reshaping the Workplace</h3>\n              <p class=\"text-neutral-300 mb-6 leading-relaxed\">Discover the emerging trends that are transforming how teams collaborate, from AI-powered workflows to distributed-first cultures. Learn what's next for your organization.</p>\n              <div class=\"flex items-center gap-4 mb-6\">\n                <div class=\"w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full\"></div>\n                <div>\n                  <p class=\"font-semibold text-neutral-100\">Alex Thompson</p>\n                  <p class=\"text-sm text-neutral-400\">March 15, 2024</p>\n                </div>\n              </div>\n              <button class=\"w-fit text-blue-500 hover:text-blue-400 font-semibold flex items-center gap-2 transition-colors\">\n                Read Article <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i>\n              </button>\n            </div>\n            <div class=\"bg-gradient-to-br from-blue-500/20 to-purple-500/20 rounded-xl flex items-center justify-center min-h-64\">\n              <i data-lucide=\"pen-tool\" class=\"w-32 h-32 text-blue-500/30\"></i>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Blog Grid -->\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n        <!-- Article 1 -->\n        <article class=\"card-hover bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden hover:border-blue-600/50\">\n          <div class=\"bg-gradient-to-br from-blue-500/20 to-cyan-500/20 h-40 flex items-