      "content": "<!DOCTYPE html>\n<html class=\"dark\" lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"referrer\" content=\"no-referrer\">\n    <title>Porsche 911 GT3 RS | Engineered for Excellence</title>\n    <script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap\" rel=\"stylesheet\">\n    <script>\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"inverse-primary\": \"#c00018\",\n                        \"tertiary-container\": \"#686a6a\",\n                        \"background\": \"#131313\",\n                        \"primary-fixed-dim\": \"#ffb3ac\",\n                        \"on-secondary-fixed-variant\": \"#474746\",\n                        \"inverse-surface\": \"#e2e2e2\",\n                        \"tertiary\": \"#c6c6c7\",\n                        \"on-primary-fixed\": \"#410003\",\n                        \"surface-container-low\": \"#1b1b1b\",\n                        \"surface-container-highest\": \"#353535\",\n                        \"tertiary-fixed\": \"#e2e2e2\",\n                        \"on-tertiary-fixed\": \"#1a1c1c\",\n                        \"on-primary-fixed-variant\": \"#930010\",\n                        \"surface-container\": \"#1f1f1f\",\n                        \"primary-container\": \"#d5001c\",\n                        \"on-secondary-container\": \"#b7b5b4\",\n                        \"on-primary\": \"#680008\",\n                        \"on-tertiary\": \"#2f3131\",\n                        \"on-secondary\": \"#303030\",\n                        \"error-container\": \"#93000a\",\n                        \"surface-container-high\": \"#2a2a2a\",\n                        \"secondary-container\": \"#474746\",\n                        \"error\": \"#ffb4ab\",\n                        \"outline\": \"#ae8884\",\n                        \"tertiary-fixed-dim\": \"#c6c6c7\",\n                        \"on-tertiary-container\": \"#eaebeb\",\n                        \"outline-variant\": \"#5e3f3c\",\n                        \"secondary\": \"#c8c6c5\",\n                        \"primary\": \"#ffb3ac\",\n                        \"on-secondary-fixed\": \"#1b1c1c\",\n                        \"on-tertiary-fixed-variant\": \"#454747\",\n                        \"surface\": \"#131313\",\n                        \"on-surface-variant\": \"#e7bcb8\",\n                        \"secondary-fixed-dim\": \"#c8c6c5\",\n                        \"surface-bright\": \"#393939\",\n                        \"on-primary-container\": \"#ffe4e2\",\n                        \"surface-dim\": \"#131313\",\n                        \"surface-variant\": \"#353535\",\n                        \"on-surface\": \"#e2e2e2\",\n                        \"on-error\": \"#690005\",\n                        \"inverse-on-surface\": \"#303030\",\n                        \"primary-fixed\": \"#ffdad6\",\n                        \"surface-tint\": \"#ffb3ac\",\n                        \"surface-container-lowest\": \"#0e0e0e\",\n                        \"on-error-container\": \"#ffdad6\",\n                        \"on-background\": \"#e2e2e2\",\n                        \"secondary-fixed\": \"#e5e2e1\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Space Grotesk\"],\n                        \"body\": [\"Inter\"],\n                        \"label\": [\"Inter\"]\n                    },\n                    borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n                }\n            }\n        }\n    </script>\n    <style>\n        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }\n        .glass-nav { backdrop-filter: blur(20px); }\n        .kerning-tight { letter-spacing: -0.05em; }\n        .primary-gradient { background: linear-gradient(45deg, #ffb3ac 0%, #d5001c 100%); }\n        body { min-height: max(884px, 100dvh); }\n    </style>\n</head>\n<body class=\"bg-background text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container flex flex-col min-h-screen\">\n\n<header class=\"fixed top-0 w-full z-50 bg-[#131313]/60 backdrop-blur-2xl flex justify-between items-center px-8 py-4\">\n    <div class=\"flex items-center gap-4\">\n        <button class=\"text-on-surface hover:text-[#D5001C] transition-colors duration-300\">\n            <span class=\"material-symbols-outlined\">menu</span>\n        </button>\n    </div>\n    <div class=\"font-headline font-bold tracking-tighter text-2xl font-black tracking-[0.2em] text-[#E2E2E2]\">\n        PORSCHE\n    </div>\n    <div class=\"flex items-center gap-6\">\n        <nav class=\"hidden md:flex gap-8 font-headline font-bold text-sm tracking-widest\">\n            <a class=\"text-[#E2E2E2] border-b-2 border-[#D5001C] transition-colors duration-300\" href=\"index.html\">MODELS</a>\n            <a class=\"text-[#E2E2E2]/70 hover:text-[#D5001C] transition-colors duration-300\" href=\"#\">RACING</a>\n            <a class=\"text-[#E2E2E2]/70 hover:text-[#D5001C] transition-colors duration-300\" href=\"experience.html\">EXPERIENCE</a>\n        </nav>\n        <button class=\"text-on-surface hover:text-[#D5001C] transition-colors duration-300\"><span class=\"material-symbols-outlined\">shopping_bag</span></button>\n    </div>\n</header>\n\n<main class=\"flex-grow\">\n    <section class=\"relative h-screen w-full flex items-center overflow-hidden bg-surface-container-lowest\">\n        <div class=\"absolute inset-0 z-0 opacity-80\">\n            <img referrerpolicy=\"no-referrer\" alt=\"Porsche 911 GT3 RS\" class=\"w-full h-full object-cover\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDNFQoIoT0G0OZSaHQpir9VbMGiRUeEn-ZsWOZa7rp5OAFvXmWf-9RavCF--S7YnrrgdBemm9dV0GB2Ui8OF-IyiKK3NJUckkxu3yChj9Tp9j7s0KnOsV2bzNNigCK7QmCbJmbDprbH18kEOJvCeOeBi4G_iLv7IXdsoTlMLsirTRN3T3ueWqh41-gwYDBMfhZQ3De9f6fPE1dOppRFoCSBTv58PdKzWJnHfsZ_ZuOkFlS7Bf0NAIWAnppJuGOohLRqIYe-osnnJiM8\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent\"></div>\n        </div>\n        <div class=\"relative z-10 max-w-7xl mx-auto px-8 w-full\">\n            <div class=\"max-w-3xl\">\n                <span class=\"font-label text-primary-container font-bold tracking-[0.3em] uppercase mb-4 block\">The New 911 GT3 RS</span>\n                <h1 class=\"font-headline text-6xl md:text-8xl font-bold kerning-tight text-on-surface leading-none mb-8\">THE SOUL OF <br/><span class=\"text-transparent bg-clip-text primary-gradient\">PERFORMANCE</span></h1>\n                <div class=\"flex flex-col md:flex-row gap-6 items-start md:items-center\">\n                    <button class=\"primary-gradient text-on-primary-fixed font-bold py-4 px-10 rounded-sm hover:opacity-90 transition-opacity uppercase tracking-widest text-sm\">Configure Yours</button>\n                    <button class=\"bg-surface-container-high text-on-surface font-bold py-4 px-10 rounded-sm hover:bg-surface-bright transition-colors uppercase tracking-widest text-sm\">Discover Details</button>\n                </div>\n            </div>\n        </div>\n        <div class=\"absolute bottom-20 right-8 hidden lg:block max-w-xs text-right\">\n            <p class=\"font-label text-xs text-on-surface-variant uppercase tracking-widest leading-loose\">Engineered for maximum downforce. Refined for the ultimate lap time. A masterpiece of aerodynamic precision.</p>\n        </div>\n    </section>\n\n    <section class=\"bg-surface py-24 px-8 border-y border-outline-variant/10\">\n        <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-24\">\n            <div class=\"flex flex-col border-l-2 border-primary-container pl-6\">\n                <span class=\"font-headline text-6xl font-bold text-on-surface\">3.2<span class=\"text-2xl ml-1 text-primary\">s</span></span>\n                <span class=\"font-label text-secondary-fixed-dim text-xs uppercase tracking-[0.2em] mt-2\">0 - 100 km/h</span>\n            </div>\n            <div class=\"flex flex-col border-l-2 border-primary-container pl-6\">\n                <span class=\"font-headline text-6xl font-bold text-on-surface\">525<span class=\"text-2xl ml-1 text-primary\">PS</span></span>\n                <span class=\"font-label text-secondary-fixed-dim text-xs uppercase tracking-[0.2em] mt-2\">Max Power Output</span>\n            </div>\n            <div class=\"flex flex-col border-l-2 border-primary-container pl-6\">\n                <span class=\"font-headline text-6xl font-bold text-on-surface\">320<span class=\"text-2xl ml-1 text-primary\">km/h</span></span>\n                <span class=\"font-label text-secondary-fixed-dim text-xs uppercase tracking-[0.2em] mt-2\">Top Track Speed</span>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"bg-surface-container-low py-32 px-8\">\n        <div class=\"max-w-7xl mx-auto\">\n            <div class=\"flex flex-col md:flex-row gap-8 mb-8\">\n                <div class=\"md:w-2/3 h-[600px] overflow-hidden group relative\">\n                    <img referrerpolicy=\"no-referrer\" alt=\"Interior\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCK4ObeAnRrEvHzCnfnxyMth5ES-sxJ0WfNWUf6I4CX4baNdJ3tRVUD1tncMs6dpOgfMSx3mn8halu6slnz1bpJtRQRzhSQVChviYxX_ihup4XTF6IO2_WJStrCQfkdKbfXMJ1LtIl5IBmBChcXvmRUucshD893pUBjHz22GE8XtxIQwszrXBxWTPwnNUSoI29pw4rfnhrSGTifWj1HHWBeJM7nh_mY_wRVu8FE3aP-5lXXeg7d2aensF7Z057C2cTdOAegHQSsShOo\">\n                    <div class=\"absolute bottom-8 left-8\"><h3 class=\"font-headline text-2xl font-bold text-on-surface\">Precision Control</h3></div>\n                </div>\n                <div class=\"md:w-1/3 flex flex-col gap-8\">\n                    <div class=\"h-[284px] overflow-hidden group relative\">\n                        <img referrerpolicy=\"no-referrer\" alt=\"Wheel\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDV6vVFQmRXfde4LUEU0mn4eanilVVkInTZM8reWGkaR9HErv8mYau7TCkR71aFP2fyk_hGj0EoqjrI2WEyZHcvkV1fq5eeOPO0YQIbGrXpQfPEq67XN8OyJNkkgIYMM4nN20QIWCy4af4SvPMYPuw5Cs1A_zPGkTJSGSX41bC1Q-RrX_qqSYTAySQba9gt4PAlwUN9GlwgHG1J8m2uGX3DtYyIHN49psv4V9NsLb_E2FFoETPgJQ-zIt0m9c_0AELLyRcR0VLo4tOu\">\n                        <span class=\"absolute bottom-4 left-4 font-label text-xs uppercase bg-primary-container px-2 py-1\">Magnesium Wheels</span>\n                    </div>\n                    <div class=\"h-[284px] overflow-hidden group relative\">\n                        <img referrerpolicy=\"no-referrer\" alt=\"Aero\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAGFAG1quxzmfw-L0ZP5z-_t-nSAGfwFBxV50SDeUa5_J9fcYbhjnjbCwa3Vk2xS2EgpOiP1nOGn3mM0K40doqHVrm-3G2oNt91qhe3hwoS5P6tOrFeinvIPdlr0yZBfTA-8vRyli8LwUcqSH6WNofSeWYU6JLMIqg6GZaJto9egy2r7b8GCUS1_1Qa62yqvg6_l-lymXJqa6BJZIrEUpYdro6rAPgarN9XWNyk2ZYx3Vi2QdB4OGYC7AgUOqTse-F1GZccdXGSDWQZ\">\n                        <span class=\"absolute bottom-4 left-4 font-label text-xs uppercase bg-surface-container-highest px-2 py-1\">Active Aero</span>\n                    </div>\n                </div>\n            </div>\n            <div class=\"flex flex-col md:flex-row-reverse gap-8\">\n                <div class=\"md:w-1/2 h-[400px] overflow-hidden group relative\">\n                    <img referrerpolicy=\"no-referrer\" alt=\"Motion\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuB5gD5XaZbEVhKu8dPxM28OrRwFyowrhxf5ZvILeeqfT_10rZuAMktFNLqm-y0z6SR4DLNJWsz78I7mZwmy0s6GV_QopVrt1B-4UxDwr4hd0VsIBeUH7M5AyMhPhLutHj3goFuDjIJktKJDrO4qJ8ImPuludU39LCdnVz5C-NGrp3ekgA7hz4IQAcfKjCAaRrhK5JiSSkCcbvipZlUe19AwvI6rsV-0k07UDX4Imnfi-bCa3UxZCO1QaSPdydqFtU9_mRsz4bGEglou\">\n                </div>\n                <div class=\"md:w-1/2 flex items-center justify-center p-12 bg-surface\">\n                    <div class=\"max-w-sm\">\n                        <h2 class=\"font-headline text-4xl font-bold mb-6\">ENGINEERED FOR EXCELLENCE</h2>\n                        <p class=\"text-secondary mb-8 leading-relaxed\">The 911 GT3 RS is designed for one thing: the track. Every curve, every vent, and every stitch is optimized for high-velocity performance and driver feedback.</p>\n                        <a class=\"inline-flex items-center gap-2 font-bold text-primary hover:gap-4 transition-all\" href=\"experience.html\">EXPLORE AERODYNAMICS <span class=\"material-symbols-outlined\">arrow_forward</span></a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"py-32 px-8 bg-surface-container-lowest text-center\">\n        <div class=\"max-w-2xl mx-auto\">\n            <h2 class=\"font-headline text-5xl font-bold mb-4\">OWN THE TRACK</h2>\n            <p class=\"text-on-surface-variant mb-12\">Experience the apex of automotive engineering. Custom-tailored to your racing DNA.</p>\n            <div class=\"flex flex-col sm:flex-row justify-center gap-4\">\n                <button class=\"primary-gradient text-on-primary-fixed font-bold py-5 px-12 rounded-sm uppercase tracking-widest text-sm\">Build Your 911 GT3 RS</button>\n                <button class=\"border border-outline-variant text-on-surface font-bold py-5 px-12 rounded-sm hover:bg-surface-container-high transition-colors uppercase tracking-widest text-sm\">Find a Dealer</button>\n            </div>\n        </div>\n    </section>\n</main>\n\n<footer class=\"bg-[#0E0E0E] w-full border-t border-[#2A2A2A]/20 mt-auto\">\n    <div class=\"max-w-7xl mx-auto px-8 py-12 flex flex-col md:flex-row justify-between items-start md:items-center\">\n        <div class=\"mb-8 md:mb-0\">\n            <div class=\"text-[#E2E2E2] font-bold font-headline tracking-[0.2em] mb-4\">PORSCHE</div>\n            <p class=\"text-[#E2E2E2]/40 text-[10px] font-['Inter'] tracking-widest uppercase\">© 2026 Dr. Ing. h.c. F. Porsche AG.</p>\n        </div>\n        <div class=\"flex flex-wrap gap-x-8 gap-y-4 font-['Inter'] text-xs tracking-widest uppercase\">\n            <a class=\"text-[#E2E2E2]/40 hover:text-[#E2E2E2] transition-all\" href=\"#\">Legal Notice</a>\n            <a class=\"text-[#E2E2E2]/40 hover:text-[#E2E2E2] transition-all\" href=\"#\">Privacy Policy</a>\n            <a class=\"text-[#E2E2E2]/40 hover:text-[#E2E2E2] transition-all\" href=\"#\">Cookie Policy</a>\n        </div>\n    </div>\n</footer>\n</body>\n</html>"
