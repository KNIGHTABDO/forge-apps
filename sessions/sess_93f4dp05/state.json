erse gap-8\">\n                <div class=\"md:w-1/2 h-[400px] overflow-hidden group relative\">\n                    <img referrerpolicy=\"no-referrer\" alt=\"Motion\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuB5gD5XaZbEVhKu8dPxM28OrRwFyowrhxf5ZvILeeqfT_10rZuAMktFNLqm-y0z6SR4DLNJWsz78I7mZwmy0s6GV_QopVrt1B-4UxDwr4hd0VsIBeUH7M5AyMhPhLutHj3goFuDjIJktKJDrO4qJ8ImPuludU39LCdnVz5C-NGrp3ekgA7hz4IQAcfKjCAaRrhK5JiSSkCcbvipZlUe19AwvI6rsV-0k07UDX4Imnfi-bCa3UxZCO1QaSPdydqFtU9_mRsz4bGEglou\">\n                </div>\n                <div class=\"md:w-1/2 flex items-center justify-center p-12 bg-surface\">\n                    <div class=\"max-w-sm\">\n                        <h2 class=\"font-headline text-4xl font-bold mb-6\">ENGINEERED FOR EXCELLENCE</h2>\n                        <p class=\"text-secondary mb-8 leading-relaxed\">The 911 GT3 RS is designed for one thing: the track. Every curve, every vent, and every stitch is optimized for high-velocity performance and driver feedback.</p>\n                        <a class=\"inline-flex items-center gap-2 font-bold text-primary hover:gap-4 transition-all\" href=\"experience.html\">EXPLORE AERODYNAMICS <span class=\"material-symbols-outlined\">arrow_forward</span></a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"py-32 px-8 bg-surface-container-lowest text-center\">\n        <div class=\"max-w-2xl mx-auto\">\n            <h2 class=\"font-headline text-5xl font-bold mb-4\">OWN THE TRACK</h2>\n            <p class=\"text-on-surface-variant mb-12\">Experience the apex of automotive engineering. Custom-tailored to your racing DNA.</p>\n            <div class=\"flex flex-col sm:flex-row justify-center gap-4\">\n                <button class=\"primary-gradient text-on-primary-fixed font-bold py-5 px-12 rounded-sm uppercase tracking-widest text-sm\">