ntainer-lowest\">\n        <div class=\"absolute inset-0 z-0 opacity-80\">\n            <img referrerpolicy=\"no-referrer\" alt=\"Porsche 911 GT3 RS\" class=\"w-full h-full object-cover\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDNFQoIoT0G0OZSaHQpir9VbMGiRUeEn-ZsWOZa7rp5OAFvXmWf-9RavCF--S7YnrrgdBemm9dV0GB2Ui8OF-IyiKK3NJUckkxu3yChj9Tp9j7s0KnOsV2bzNNigCK7QmCbJmbDprbH18kEOJvCeOeBi4G_iLv7IXdsoTlMLsirTRN3T3ueWqh41-gwYDBMfhZQ3De9f6fPE1dOppRFoCSBTv58PdKzWJnHfsZ_ZuOkFlS7Bf0NAIWAnppJuGOohLRqIYe-osnnJiM8\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent\"></div>\n        </div>\n        <div class=\"relative z-10 max-w-7xl mx-auto px-8 w-full\">\n            <div class=\"max-w-3xl\">\n                <span class=\"font-label text-primary-container font-bold tracking-[0.3em] uppercase mb-4 block\">The New 911 GT3 RS</span>\n                <h1 class=\"font-headline text-6xl md:text-8xl font-bold kerning-tight text-on-surface leading-none mb-8\">THE SOUL OF <br/><span class=\"text-transparent bg-clip-text primary-gradient\">PERFORMANCE</span></h1>\n                <div class=\"flex flex-col md:flex-row gap-6 items-start md:items-center\">\n                    <button class=\"primary-gradient text-on-primary-fixed font-bold py-4 px-10 rounded-sm hover:opacity-90 transition-opacity uppercase tracking-widest text-sm\">Configure Yours</button>\n                    <button class=\"bg-surface-container-high text-on-surface font-bold py-4 px-10 rounded-sm hover:bg-surface-bright transition-colors uppercase tracking-widest text-sm\">Discover Details</button>\n                </div>\n            </div>\n        </div>\n        <div class=\"absolute bottom-20 right-8 hidden lg:block max-w-xs text-right\">\n            <p class=\"font-label text-xs text-on-surface-variant uppercase tracking-widest leading-loose\">Engineered for maximum downforce. Refined for the ultimate lap time. A masterpiece of aerodynamic precision.</p>\n        </div>\n    </section>\n\n    <section class=\"bg-surface py-24 px-8 border-y border-outline-variant/10\">\n        <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-24\">\n            <div class=\"flex flex-col border-l-2 border-primary-container pl-6\">\n                <span class=\"font-headline text-6xl font-bold text-on-surface\">3.2<span class=\"text-2xl ml-1 text-primary\">s</span></span>\n                <span class=\"font-label text-secondary-fixed-dim text-xs uppercase tracking-[0.2em] mt-2\">0 - 100 km/h</span>\n            </div>\n            <div class=\"flex flex-col border-l-2 border-primary-container pl-6\">\n                <span class=\"font-headline text-6xl font-bold text-on-surface\">525<span class=\"text-2xl ml-1 text-primary\">PS</span></span>\n                <span class=\"font-label text-secondary-fixed-dim text-xs uppercase tracking-[0.2em] mt-2\">Max Power Output</span>\n            </div>\n            <div class=\"flex flex-col border-l-2 border-primary-container pl-6\">\n                <span class=\"font-headline text-6xl font-bold text-on-surface\">320<span class=\"text-2xl ml-1 text-primary\">km/h</span></span>\n                <span class=\"font-label text-secondary-fixed-dim text-xs uppercase tracking-[0.2em] mt-2\">Top Track Speed</span>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"bg-surface-container-low py-32 px-8\">\n        <div class=\"max-w-7xl mx-auto\">\n            <div class=\"flex flex-col md:flex-row gap-8 mb-8\">\n                <div class=\"md:w-2/3 h-[600px] overflow-hidden group relative\">\n                    <img referrerpolicy=\"no-referrer\" alt=\"Interior\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCK4ObeAnRrEvHzCnfnxyMth5ES-sxJ0WfNWUf6I4CX4baNdJ3tRVUD1tncMs6dpOgfMSx3mn8halu6slnz1bpJtRQRzhSQVChviYxX_ihup4XTF6IO2_WJStrCQfkd