  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Minimalist Task List</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');\n        :root {\n            --bg:#0a0a0a; --s1:#111111; --s2:#1a1a1a; --s3:#242424; --border:#1e293b;\n            --text:#f1f5f9; --muted:#64748b; --accent:#3b82f6; --accent-h:#2563eb;\n            --danger:#ef4444; --success:#22c55e;\n        }\n        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }\n        .container { width: 100%; max-width: 500px; padding: 2rem; box-sizing: border-box; }\n        h1 { font-size: 1.5rem; margin-bottom: 2rem; color: var(--muted); }\n        .input-group { display: flex; gap: 8px; margin-bottom: 2rem; }\n        input { flex: 1; background: var(--s1); border: 1px solid var(--border); color: var(--text); padding: 12px 16px; border-radius: 8px; outline: none; }\n        input:focus { border-color: var(--accent); }\n        button { background: var(--accent); color: white; border: none; padding: 0 20px; border-radius: 8px; cursor: pointer; font-weight: 600; }\n        button:hover { background: var(--accent-h); }\n        .task-list { display: flex; flex-direction: column; gap: 8px; }\n        .task-item { background: var(--s1); padding: 12px 16px; border-radius: 8px; border: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; animation: fadeIn 0.2s ease; }\n        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }\n        .delete-btn { color: var(--danger); background: none; border: none; padding: 4px; cursor: pointer; }\n        .empty { text-align: center; color: var(--muted); padding: 2rem; }\n        .actions { margin-top: 2rem; display: flex; justify-content: space-between; }\n        .export-btn { background: none; border: 1px solid var(--border); color: var(--muted); font-size: 12px; cursor: pointer; }\n    </style>\n</head>\n<body>\n\n<div class=\"container\">\n    <h1>Focus.</h1>\n    <form id=\"task-form\" class=\"input-group\">\n        <input type=\"text\" id=\"task-input\" placeholder=\"What needs to be done?\" required autofocus>\n        <button type=\"submit\">Add</button>\n    </form>\n\n    <div id=\"task-list\" class=\"task-list\"></div>\n    \n    <div class=\"actions\">\n        <button class=\"export-btn\" onclick=\"exportCSV()\">Export CSV</button>\n        <button class=\"export-btn\" onclick=\"clearCompleted()\">Clear Finished</button>\n    </div>\n</div>\n\n<footer style=\"text-align:center;padding:16px;color:var(--muted);font-size:12px;opacity:0.8;display:flex;justify-content:center;align-items:center;gap:6px\"><span>Built with</span> <img src=\"https://forge-app.vercel.app/logo.png\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> <a href=\"https://forge-app.vercel.app\" style=\"color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:0.05em\">FORGE</a></footer>\n\n<script>\n    const KEY = 'forge-todo-v1';\n    const form = document.getElementById('task-form');\n    const input = document.getElementById('task-input');\n    const list = document.getElementById('task-list');\n\n    let tasks = JSON.parse(localStorage.getItem(KEY) || '[]');\n\n    const save = () => {\n        localStorage.setItem(KEY, JSON.stringify(tasks));\n        render();\n    };\n\n    const render = () => {\n        list.innerHTML = '';\n        if (tasks.length === 0) {\n            list.innerHTML = '<div class=\"empty\">No active tasks. Good job.</div>';\n            return;\n        }\n        tasks.forEach((t, i) => {\n            const div = document.createElement('div');\n            div.className = 'task-item';\n            div.innerHTML = `\n                <span>${t.text}</span>\n                <button class=\"delete-btn\" onclick=\"removeTask(${i})\">✕</button>\n            `;\n            list.appendChild(div);\n        });\n    };\n\n    form.onsubmit = (e) => {\n        e.preventDefault();\n        if (!input.value.trim()) return;\n        tasks.push({ text: input.value.trim(), date: new Date().toISOString() });\n        input.value = '';\n        save();\n    };\n\n    const removeTask = (i) => {\n        tasks.splice(i, 1);\n        save();\n    };\n\n    const clearCompleted = () => {\n        tasks = [];\n        save();\n    };\n\n    const exportCSV = () => {\n        const csv = 'Task,Date\\n' + tasks.map(t => `\"${t.text}\",\"${t.date}\"`).join('\\n');\n        const blob = new Blob([csv], { type: 'text/csv' });\n        const url = URL.createObjectURL(blob);\n        const a = document.createElement('a');\n        a.href = url;\n        a.download = 'tasks.csv';\n        a.click();\n    };\n\n    document.addEventListener('keydown', (e) => {\n        if ((e.metaKey || e.ctrlKey) && e.key === 'n') {\n            e.preventDefault();\n            input.focus();\n        }\n    });\n\n    render();\n</script>\n</body>\n</html>",
