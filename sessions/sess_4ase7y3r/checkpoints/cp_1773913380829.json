  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>FORGE | Stream Dashboard</title>\n    <style>\n        :root {\n            --bg: #0a0a0a; --s1: #111111; --s2: #1a1a1a; --s3: #242424; --border: #1e293b;\n            --text: #f1f5f9; --muted: #64748b; --accent: #e50914; --accent-h: #b80710;\n        }\n        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 0; }\n        header { padding: 20px 4%; display: flex; align-items: center; background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, transparent 100%); position: fixed; width: 100%; z-index: 100; box-sizing: border-box; }\n        .logo { color: var(--accent); font-weight: 800; font-size: 24px; letter-spacing: -1px; margin-right: 30px; }\n        .hero { height: 70vh; background: linear-gradient(to right, #000 10%, transparent 80%), url('https://picsum.photos/1600/900?random=1'); background-size: cover; display: flex; align-items: center; padding: 0 4%; }\n        .content-row { padding: 20px 4%; }\n        .row-title { font-size: 1.2rem; margin-bottom: 15px; }\n        .slider { display: flex; gap: 10px; overflow-x: auto; scrollbar-width: none; }\n        .slider::-webkit-scrollbar { display: none; }\n        .card { flex: 0 0 200px; height: 300px; background: var(--s2); border-radius: 4px; position: relative; cursor: pointer; transition: transform 0.3s; }\n        .card:hover { transform: scale(1.05); }\n        .card img { width: 100%; height: 100%; object-fit: cover; border-radius: 4px; }\n        button { background: var(--accent); color: white; border: none; padding: 10px 25px; border-radius: 4px; font-weight: 600; cursor: pointer; }\n        button:hover { background: var(--accent-h); }\n        .my-list { position: fixed; bottom: 20px; right: 20px; background: var(--s3); padding: 15px; border-radius: 8px; border: 1px solid var(--border); width: 250px; }\n    </style>\n</head>\n<body>\n\n<header>\n    <div class=\"logo\">FORGEFLIX</div>\n</header>\n\n<div class=\"hero\">\n    <div>\n        <h1>Featured Content</h1>\n        <p style=\"max-width: 500px; color: #ddd; margin-bottom: 20px;\">Stream the latest hits and classic cinema. Personalized for you based on your history.</p>\n        <button onclick=\"alert('Playing feature...')\">Play</button>\n    </div>\n</div>\n\n<div class=\"content-row\">\n    <div class=\"row-title\">Trending Now</div>\n    <div class=\"slider\" id=\"trending-list\"></div>\n</div>\n\n<div class=\"my-list\">\n    <h3>My List</h3>\n    <div id=\"list-items\" style=\"font-size: 0.9rem; color: var(--muted);\"></div>\n    <button style=\"width: 100%; margin-top: 10px; font-size: 0.8rem;\" onclick=\"exportList()\">Export List CSV</button>\n</div>\n\n<footer style=\"text-align:center;padding:16px;color:var(--muted);font-size:12px;opacity:0.8;display:flex;justify-content:center;align-items:center;gap:6px\"><span>Built with</span> <img src=\"https://forge-app-peach.vercel.app/logo.png\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> <a href=\"https://forge-app-peach.vercel.app\" style=\"color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:0.05em\">FORGE</a></footer>\n\n<script>\n    const KEY = 'forge-netflix-v1';\n    let myList = JSON.parse(localStorage.getItem(KEY) || '[]');\n\n    const movies = [\n        {id: 1, title: 'Inception', img: 'https://picsum.photos/400/600?random=1'},\n        {id: 2, title: 'Interstellar', img: 'https://picsum.photos/400/600?random=2'},\n        {id: 3, title: 'The Batman', img: 'https://picsum.photos/400/600?random=3'},\n        {id: 4, title: 'Dune', img: 'https://picsum.photos/400/600?random=4'},\n        {id: 5, title: 'Joker', img: 'https://picsum.photos/400/600?random=5'}\n    ];\n\n    function toggleList(movie) {\n        const idx = myList.findIndex(m => m.id === movie.id);\n        if (idx > -1) myList.splice(idx, 1);\n        else myList.push(movie);\n        localStorage.setItem(KEY, JSON.stringify(myList));\n        render();\n    }\n\n    function render() {\n        const container = document.getElementById('trending-list');\n        const listDiv = document.getElementById('list-items');\n        container.innerHTML = '';\n        listDiv.innerHTML = myList.length ? '' : 'No items added yet.';\n\n        movies.forEach(m => {\n            const card = document.createElement('div');\n            card.className = 'card';\n            card.innerHTML = `<img src=\"${m.img}\" onclick=\"toggleList(${JSON.stringify(m).replace(/\"/g, '&quot;')})\">`;\n            container.appendChild(card);\n        });\n\n        myList.forEach(m => {\n            const item = document.createElement('div');\n            item.style.padding = '5px 0';\n            item.textContent = `+ ${m.title}`;\n            listDiv.appendChild(item);\n        });\n    }\n\n    function exportList() {\n        let csv = 'Title\\n' + myList.map(m => m.title).join('\\n');\n        const blob = new Blob([csv], {type: 'text/csv'});\n        const url = URL.createObjectURL(blob);\n        const a = document.createElement('a');\n        a.href = url;\n        a.download = 'my-list.csv';\n        a.click();\n    }\n\n    render();\n</script>\n</body>\n</html>",
