  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Pomodoro Focus Timer</title>\n    <style>\n        :root {\n            --bg:#0a0a0a; --s1:#111111; --s2:#1a1a1a; --s3:#242424; --border:#1e293b;\n            --text:#f1f5f9; --muted:#64748b; --accent:#3b82f6; --accent-h:#2563eb;\n            --danger:#ef4444; --success:#22c55e;\n        }\n        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }\n        .container { width: 100%; max-width: 400px; }\n        .timer-display { font-size: 5rem; font-weight: 800; text-align: center; margin: 2rem 0; font-variant-numeric: tabular-nums; }\n        .controls { display: flex; gap: 10px; justify-content: center; }\n        button { padding: 12px 24px; border-radius: 8px; border: none; cursor: pointer; font-weight: 600; transition: 0.15s; background: var(--s3); color: white; }\n        button:hover { background: var(--border); }\n        button.primary { background: var(--accent); }\n        button.primary:hover { background: var(--accent-h); }\n        .log-section { margin-top: 3rem; width: 100%; }\n        .log-item { background: var(--s1); padding: 12px; margin-bottom: 8px; border-radius: 8px; display: flex; justify-content: space-between; font-size: 0.9rem; border: 1px solid var(--border); }\n        h2 { font-size: 1.2rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }\n    </style>\n</head>\n<body>\n\n<div class=\"container\">\n    <h1 style=\"text-align: center; font-size: 1.5rem;\">Focus Timer</h1>\n    <div class=\"timer-display\" id=\"display\">25:00</div>\n    \n    <div class=\"controls\">\n        <button id=\"startBtn\" class=\"primary\">Start</button>\n        <button id=\"resetBtn\">Reset</button>\n    </div>\n\n    <div class=\"log-section\">\n        <h2>Session Log</h2>\n        <div id=\"logList\"></div>\n        <button id=\"exportBtn\" style=\"margin-top:10px; width:100%; background:transparent; border:1px solid var(--border)\">Export CSV</button>\n    </div>\n</div>\n\n<footer style=\"text-align:center;padding:16px;color:var(--muted);font-size:12px;opacity:0.8;display:flex;justify-content:center;align-items:center;gap:6px\"><span>Built with</span> <img src=\"https://forge-app.vercel.app/logo.png\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> <a href=\"https://forge-app.vercel.app\" style=\"color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:0.05em\">FORGE</a></footer>\n\n<script>\n    const KEY = 'forge-pomodoro-v1';\n    let timeLeft = 1500;\n    let timerId = null;\n    let isRunning = false;\n\n    const display = document.getElementById('display');\n    const startBtn = document.getElementById('startBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const logList = document.getElementById('logList');\n    const exportBtn = document.getElementById('exportBtn');\n\n    const loadLog = () => JSON.parse(localStorage.getItem(KEY) || '[]');\n    const saveLog = (log) => localStorage.setItem(KEY, JSON.stringify(log));\n\n    function updateDisplay() {\n        const m = Math.floor(timeLeft / 60);\n        const s = timeLeft % 60;\n        display.textContent = `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;\n    }\n\n    function renderLog() {\n        const log = loadLog();\n        logList.innerHTML = log.length ? '' : '<div style=\"color:var(--muted); text-align:center; padding:20px;\">No sessions yet</div>';\n        log.slice().reverse().forEach(entry => {\n            const div = document.createElement('div');\n            div.className = 'log-item';\n            div.innerHTML = `<span>Completed</span> <span>${new Date(entry).toLocaleTimeString()}</span>`;\n            logList.appendChild(div);\n        });\n    }\n\n    startBtn.addEventListener('click', () => {\n        if (isRunning) {\n            clearInterval(timerId);\n            startBtn.textContent = 'Start';\n            isRunning = false;\n        } else {\n            isRunning = true;\n            startBtn.textContent = 'Pause';\n            timerId = setInterval(() => {\n                timeLeft--;\n                updateDisplay();\n                if (timeLeft <= 0) {\n                    clearInterval(timerId);\n                    alert(\"Focus session complete!\");\n                    const log = loadLog();\n                    log.push(Date.now());\n                    saveLog(log);\n                    renderLog();\n                    timeLeft = 1500;\n                    updateDisplay();\n                    startBtn.textContent = 'Start';\n                    isRunning = false;\n                }\n            }, 1000);\n        }\n    });\n\n    resetBtn.addEventListener('click', () => {\n        clearInterval(timerId);\n        timeLeft = 1500;\n        isRunning = false;\n        startBtn.textContent = 'Start';\n        updateDisplay();\n    });\n\n    exportBtn.addEventListener('click', () => {\n        const log = loadLog();\n        const csv = \"data:text/csv;charset=utf-8,\" + log.map(d => new Date(d).toISOString()).join(\"\\n\");\n        const encoded = encodeURI(csv);\n        const link = document.createElement(\"a\");\n        link.setAttribute(\"href\", encoded);\n        link.setAttribute(\"download\", \"pomodoro_log.csv\");\n        document.body.appendChild(link);\n        link.click();\n    });\n\n    renderLog();\n    updateDisplay();\n</script>\n</body>\n</html>",
