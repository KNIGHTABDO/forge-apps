  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script src=\"/forge.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js\"></script>\n    <title>Calorie Tracker | FORGE</title>\n</head>\n<body class=\"bg-neutral-950 text-neutral-100 min-h-screen flex flex-col font-sans\">\n\n    <main class=\"flex-grow p-4 md:p-8 max-w-4xl mx-auto w-full\">\n        <header class=\"mb-8\">\n            <h1 class=\"text-3xl font-bold tracking-tight\">Calorie Tracker</h1>\n            <p class=\"text-neutral-400\">Track your daily intake and maintain your goals.</p>\n        </header>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            <!-- Entry Form -->\n            <div class=\"backdrop-blur-md bg-neutral-900/50 border border-neutral-800 p-6 rounded-2xl shadow-lg shadow-black/50\">\n                <h2 class=\"text-lg font-semibold mb-4 flex items-center gap-2\"><i data-lucide=\"plus-circle\" class=\"w-5 h-5 text-blue-500\"></i>Add Food</h2>\n                <form id=\"calorieForm\" class=\"space-y-4\">\n                    <div>\n                        <label class=\"block text-xs uppercase tracking-wider text-neutral-500 mb-1\">Food Item</label>\n                        <input type=\"text\" id=\"foodName\" required class=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg p-3 focus:ring-2 focus:ring-blue-500 outline-none transition\">\n                    </div>\n                    <div>\n                        <label class=\"block text-xs uppercase tracking-wider text-neutral-500 mb-1\">Calories</label>\n                        <input type=\"number\" id=\"calories\" required min=\"0\" class=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg p-3 focus:ring-2 focus:ring-blue-500 outline-none transition\">\n                    </div>\n                    <button type=\"submit\" class=\"w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-lg transition-all shadow-md shadow-blue-900/20\">Add to Daily Log</button>\n                </form>\n            </div>\n\n            <!-- Stats Card -->\n            <div class=\"backdrop-blur-md bg-neutral-900/50 border border-neutral-800 p-6 rounded-2xl shadow-lg shadow-black/50 flex flex-col justify-center items-center\">\n                <div class=\"text-neutral-500 text-sm uppercase tracking-widest mb-2\">Total Today</div>\n                <div id=\"totalCalories\" class=\"text-6xl font-black text-blue-500\">0</div>\n                <div class=\"text-neutral-400 mt-2\">kcal</div>\n            </div>\n        </div>\n\n        <!-- Log Table -->\n        <div class=\"mt-8 backdrop-blur-md bg-neutral-900/50 border border-neutral-800 rounded-2xl overflow-hidden shadow-lg shadow-black/50\">\n            <div class=\"p-6 border-b border-neutral-800 flex justify-between items-center\">\n                <h2 class=\"text-lg font-semibold\">Today's Log</h2>\n                <button id=\"exportBtn\" class=\"text-xs flex items-center gap-1.5 px-3 py-1.5 bg-neutral-800 rounded-md hover:bg-neutral-700 transition\">\n                    <i data-lucide=\"download\" class=\"w-3.5 h-3.5\"></i> Export CSV\n                </button>\n            </div>\n            <div id=\"logEntries\" class=\"divide-y divide-neutral-800\">\n                <!-- Data injected here -->\n            </div>\n        </div>\n    </main>\n\n    <footer class=\"text-center p-4 text-neutral-400 text-xs opacity-80 flex justify-center items-center gap-1.5 mt-auto\">\n        <span>Built with</span> <img src=\"https://forge-app.vercel.app/logo.png\" alt=\"Forge\" class=\"w-3.5 h-3.5 rounded-sm object-cover\"> <a href=\"https://forge-app.vercel.app\" class=\"text-blue-500 font-semibold tracking-wide no-underline\">FORGE</a>\n    </footer>\n\n    <script>\n        const SLUG = 'calorie-tracker-v1';\n        let state = [];\n\n        async function init() {\n            lucide.createIcons();\n            const saved = await window.forge.db.get(SLUG, 'data') || [];\n            state = saved;\n            render();\n        }\n\n        document.getElementById('calorieForm').onsubmit = async (e) => {\n            e.preventDefault();\n            const food = document.getElementById('foodName').value;\n            const kcal = parseInt(document.getElementById('calories').value);\n            \n            state.unshift({ food, kcal, id: Date.now() });\n            await window.forge.db.set(SLUG, 'data', state);\n            e.target.reset();\n            render();\n        };\n\n        function render() {\n            const container = document.getElementById('logEntries');\n            const totalEl = document.getElementById('totalCalories');\n            \n            const total = state.reduce((acc, curr) => acc + curr.kcal, 0);\n            totalEl.textContent = total;\n\n            if (state.length === 0) {\n                container.innerHTML = `<div class=\"p-8 text-center text-neutral-500 text-sm\">No entries yet today. Start tracking!</div>`;\n            } else {\n                container.innerHTML = state.map(entry => `\n                    <div class=\"p-4 flex justify-between items-center hover:bg-neutral-800/30 transition\">\n                        <div>\n                            <div class=\"font-medium\">${entry.food}</div>\n                        </div>\n                        <div class=\"font-bold text-blue-400\">${entry.kcal} kcal</div>\n                    </div>\n                `).join('');\n            }\n            lucide.createIcons();\n        }\n\n        document.getElementById('exportBtn').onclick = () => {\n            const csv = \"Food,Calories\\n\" + state.map(e => `${e.food},${e.kcal}`).join('\\n');\n            const blob = new Blob([csv], { type: 'text/csv' });\n            const url = URL.createObjectURL(blob);\n            const a = document.createElement('a');\n            a.href = url;\n            a.download = 'calories.csv';\n            a.click();\n        };\n\n        init();\n    </script>\n</body>\n</html>",
