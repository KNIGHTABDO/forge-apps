  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Calculator | FORGE</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');\n        :root {\n            --bg:#0a0a0a; --s1:#111111; --s2:#1a1a1a; --s3:#242424; --border:#1e293b;\n            --text:#f1f5f9; --muted:#64748b; --accent:#3b82f6; --accent-h:#2563eb;\n            --danger:#ef4444; --success:#22c55e; --warning:#f59e0b;\n        }\n        [data-theme='light'] {\n            --bg:#f8fafc; --s1:#ffffff; --s2:#f1f5f9; --s3:#e2e8f0; --border:#cbd5e1;\n            --text:#0f172a; --muted:#475569;\n        }\n        * { box-sizing: border-box; font-family: 'Inter', sans-serif; transition: background 0.2s, color 0.2s; }\n        body { background: var(--bg); color: var(--text); margin: 0; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; }\n        .calc-container { background: var(--s1); padding: 24px; border-radius: 16px; border: 1px solid var(--border); width: 100%; max-width: 320px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }\n        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }\n        #display { width: 100%; height: 60px; background: var(--s2); border: 1px solid var(--border); border-radius: 8px; margin-bottom: 20px; text-align: right; padding: 10px; font-size: 24px; color: var(--text); outline: none; }\n        .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }\n        button { aspect-ratio: 1; border: none; border-radius: 8px; background: var(--s3); color: var(--text); font-size: 18px; font-weight: 600; cursor: pointer; }\n        button:hover { filter: brightness(1.2); }\n        button.op { background: var(--accent); color: white; }\n        button.span-2 { grid-column: span 2; aspect-ratio: auto; padding: 15px 0; }\n        button.clear { background: var(--danger); color: white; }\n        .theme-toggle { cursor: pointer; background: var(--s2); border: 1px solid var(--border); border-radius: 6px; padding: 5px 10px; font-size: 12px; }\n    </style>\n</head>\n<body data-theme=\"dark\">\n\n<div class=\"calc-container\">\n    <div class=\"header\">\n        <span style=\"font-weight:600; font-size:14px\">CALCULATOR</span>\n        <button class=\"theme-toggle\" onclick=\"toggleTheme()\">Theme</button>\n    </div>\n    <input type=\"text\" id=\"display\" readonly value=\"0\">\n    <div class=\"grid\">\n        <button class=\"clear\" onclick=\"clearDisplay()\">C</button>\n        <button onclick=\"appendOp('/')\">/</button>\n        <button onclick=\"appendOp('*')\">×</button>\n        <button onclick=\"backspace()\">DEL</button>\n        <button onclick=\"append('7')\">7</button>\n        <button onclick=\"append('8')\">8</button>\n        <button onclick=\"append('9')\">9</button>\n        <button class=\"op\" onclick=\"appendOp('-')\">-</button>\n        <button onclick=\"append('4')\">4</button>\n        <button onclick=\"append('5')\">5</button>\n        <button onclick=\"append('6')\">6</button>\n        <button class=\"op\" onclick=\"appendOp('+')\">+</button>\n        <button onclick=\"append('1')\">1</button>\n        <button onclick=\"append('2')\">2</button>\n        <button onclick=\"append('3')\">3</button>\n        <button class=\"op\" onclick=\"calculate()\">=</button>\n        <button class=\"span-2\" onclick=\"append('0')\">0</button>\n        <button onclick=\"append('.')\">.</button>\n    </div>\n</div>\n\n<footer style=\"text-align:center;padding:16px;color:var(--muted);font-size:12px;opacity:0.8;display:flex;justify-content:center;align-items:center;gap:6px\"><span>Built with</span> <img src=\"https://forge-app.vercel.app/logo.png\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> <a href=\"https://forge-app.vercel.app\" style=\"color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:0.05em\">FORGE</a></footer>\n\n<script>\n    const display = document.getElementById('display');\n    const KEY = 'forge-calc-v1';\n    const THEME_KEY = 'forge-calc-theme';\n\n    const theme = localStorage.getItem(THEME_KEY) || 'dark';\n    document.body.setAttribute('data-theme', theme);\n\n    let current = localStorage.getItem(KEY) || '0';\n    display.value = current;\n\n    function save() { localStorage.setItem(KEY, display.value); }\n\n    function toggleTheme() {\n        const newTheme = document.body.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';\n        document.body.setAttribute('data-theme', newTheme);\n        localStorage.setItem(THEME_KEY, newTheme);\n    }\n\n    function append(val) {\n        if (display.value === '0') display.value = val;\n        else display.value += val;\n        save();\n    }\n\n    function appendOp(op) {\n        const last = display.value.slice(-1);\n        if (['+', '-', '*', '/'].includes(last)) {\n            display.value = display.value.slice(0, -1) + op;\n        } else {\n            display.value += op;\n        }\n        save();\n    }\n\n    function clearDisplay() {\n        display.value = '0';\n        save();\n    }\n\n    function backspace() {\n        display.value = display.value.length > 1 ? display.value.slice(0, -1) : '0';\n        save();\n    }\n\n    function calculate() {\n        try {\n            display.value = Function('\"use strict\";return (' + display.value + ')')();\n            save();\n        } catch (e) {\n            display.value = 'Error';\n            setTimeout(clearDisplay, 1500);\n        }\n    }\n</script>\n</body>\n</html>",
