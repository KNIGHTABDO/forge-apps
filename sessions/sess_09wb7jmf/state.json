  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>ForgeTube</title>\n    <style>\n        :root {\n            --bg: #0a0a0a; --s1: #111111; --s2: #1a1a1a; --s3: #242424; \n            --border: #1e293b; --text: #f1f5f9; --muted: #64748b; \n            --accent: #3b82f6; --accent-h: #2563eb; --danger: #ef4444;\n        }\n        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 0; }\n        header { background: var(--s1); padding: 1rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }\n        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }\n        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }\n        .video-card { background: var(--s1); border-radius: 8px; overflow: hidden; border: 1px solid var(--border); cursor: pointer; transition: 0.2s; }\n        .video-card:hover { transform: translateY(-4px); border-color: var(--accent); }\n        .thumb { width: 100%; height: 160px; background: var(--s3); display: flex; align-items: center; justify-content: center; }\n        .info { padding: 12px; }\n        .title { font-weight: bold; margin-bottom: 4px; display: block; }\n        .meta { color: var(--muted); font-size: 0.85rem; }\n        input, button { background: var(--s2); border: 1px solid var(--border); color: var(--text); padding: 10px; border-radius: 4px; }\n        .form-box { background: var(--s1); padding: 20px; border-radius: 8px; margin-bottom: 30px; display: flex; gap: 10px; flex-wrap: wrap; }\n    </style>\n</head>\n<body>\n\n<header>\n    <div style=\"font-weight: 800; font-size: 1.5rem;\">FORGE<span style=\"color:var(--danger)\">TUBE</span></div>\n</header>\n\n<div class=\"container\">\n    <div class=\"form-box\">\n        <input type=\"text\" id=\"vidTitle\" placeholder=\"Video Title\" style=\"flex:2\">\n        <input type=\"text\" id=\"vidUrl\" placeholder=\"Video ID (e.g. dQw4w9WgXcQ)\" style=\"flex:1\">\n        <button onclick=\"addVideo()\" style=\"background:var(--accent); cursor:pointer\">Add to Queue</button>\n    </div>\n\n    <div id=\"videoList\" class=\"grid\"></div>\n</div>\n\n<footer style=\"text-align:center;padding:16px;color:var(--muted);font-size:12px;opacity:0.8;display:flex;justify-content:center;align-items:center;gap:6px\">\n    <span>Built with</span> <img src=\"https://forge-app.vercel.app/logo.svg\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> \n    <a href=\"https://forge-app.vercel.app\" style=\"color:var(--accent);text-decoration:none;font-weight:600\">FORGE</a>\n</footer>\n\n<script>\n    const KEY = 'forge-youtube-v1';\n    let data = JSON.parse(localStorage.getItem(KEY) || '[]');\n\n    function render() {\n        const list = document.getElementById('videoList');\n        list.innerHTML = data.length === 0 ? '<p style=\"color:var(--muted)\">No videos added yet.</p>' : '';\n        data.forEach((v, i) => {\n            const card = document.createElement('div');\n            card.className = 'video-card';\n            card.innerHTML = `\n                <div class=\"thumb\"><img src=\"https://img.youtube.com/vi/${v.url}/mqdefault.jpg\" style=\"width:100%; height:100%; object-fit:cover\"></div>\n                <div class=\"info\">\n                    <span class=\"title\">${v.title}</span>\n                    <span class=\"meta\">ID: ${v.url}</span>\n                    <button onclick=\"remove(${i})\" style=\"margin-top:10px; background:var(--danger); border:none; width:100%; cursor:pointer\">Remove</button>\n                </div>\n            `;\n            list.appendChild(card);\n        });\n    }\n\n    function addVideo() {\n        const title = document.getElementById('vidTitle').value;\n        const url = document.getElementById('vidUrl').value;\n        if (!title || !url) return;\n        data.push({ title, url });\n        localStorage.setItem(KEY, JSON.stringify(data));\n        render();\n        document.getElementById('vidTitle').value = '';\n        document.getElementById('vidUrl').value = '';\n    }\n\n    function remove(i) {\n        data.splice(i, 1);\n        localStorage.setItem(KEY, JSON.stringify(data));\n        render();\n    }\n\n    render();\n</script>\n</body>\n</html>",
