  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Daily Habit Tracker</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --bg:#0a0a0a; --s1:#111111; --s2:#1a1a1a; --s3:#242424; --border:#1e293b;\n            --text:#f1f5f9; --muted:#64748b; --accent:#3b82f6; --accent-h:#2563eb;\n            --danger:#ef4444; --success:#22c55e;\n        }\n        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; display: flex; flex-direction: column; align-items: center; }\n        .container { width: 100%; max-width: 500px; }\n        h1 { font-size: 1.5rem; text-align: center; margin-bottom: 2rem; }\n        .habit-card { background: var(--s1); border: 1px solid var(--border); padding: 16px; border-radius: 12px; margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between; }\n        .habit-name { flex: 1; font-weight: 600; }\n        .checkbox { width: 32px; height: 32px; cursor: pointer; accent-color: var(--success); }\n        .stats { margin-top: 2rem; background: var(--s2); padding: 16px; border-radius: 12px; text-align: center; }\n        button { background: var(--s3); border: none; color: var(--text); padding: 8px 16px; border-radius: 6px; cursor: pointer; transition: 0.2s; }\n        button:hover { background: var(--accent); }\n    </style>\n</head>\n<body>\n\n<div class=\"container\">\n    <h1>Daily Habits</h1>\n    <div id=\"habits-list\"></div>\n    <div class=\"stats\">\n        <p>Today's Progress: <span id=\"progress-text\">0/5</span></p>\n        <button onclick=\"resetHabits()\">Reset All</button>\n    </div>\n</div>\n\n<footer style=\"text-align:center;padding:16px;color:var(--muted);font-size:12px;opacity:0.8;display:flex;justify-content:center;align-items:center;gap:6px\"><span>Built with</span> <img src=\"https://forge-app-peach.vercel.app/logo.png\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> <a href=\"https://forge-app-peach.vercel.app\" style=\"color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:0.05em\">FORGE</a></footer>\n\n<script>\n    const KEY = 'forge-habit-tracker-v1';\n    const habitNames = [\"Morning Exercise\", \"Read 30 mins\", \"Drink 2L Water\", \"Deep Work\", \"Journaling\"];\n    \n    let state = JSON.parse(localStorage.getItem(KEY)) || {\n        date: new Date().toLocaleDateString(),\n        completed: [false, false, false, false, false]\n    };\n\n    function init() {\n        const today = new Date().toLocaleDateString();\n        if (state.date !== today) {\n            state = { date: today, completed: [false, false, false, false, false] };\n            save();\n        }\n        render();\n    }\n\n    function save() {\n        localStorage.setItem(KEY, JSON.stringify(state));\n        render();\n    }\n\n    function render() {\n        const list = document.getElementById('habits-list');\n        list.innerHTML = '';\n        state.completed.forEach((val, i) => {\n            const div = document.createElement('div');\n            div.className = 'habit-card';\n            div.innerHTML = `\n                <span class=\"habit-name\">${habitNames[i]}</span>\n                <input type=\"checkbox\" class=\"checkbox\" ${val ? 'checked' : ''} onchange=\"toggle(${i})\">\n            `;\n            list.appendChild(div);\n        });\n        document.getElementById('progress-text').innerText = `${state.completed.filter(Boolean).length}/5`;\n    }\n\n    function toggle(i) {\n        state.completed[i] = !state.completed[i];\n        save();\n    }\n\n    function resetHabits() {\n        if(confirm('Clear all progress?')) {\n            state.completed = [false, false, false, false, false];\n            save();\n        }\n    }\n\n    init();\n</script>\n</body>\n</html>",
