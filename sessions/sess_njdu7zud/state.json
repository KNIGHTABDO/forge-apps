  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Secure Password Generator</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');\n        :root {\n            --bg:#0a0a0a; --s1:#111111; --s2:#1a1a1a; --s3:#242424; --border:#1e293b;\n            --text:#f1f5f9; --muted:#64748b; --accent:#3b82f6; --accent-h:#2563eb;\n            --danger:#ef4444; --success:#22c55e;\n        }\n        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }\n        .card { background: var(--s1); border: 1px solid var(--border); padding: 2rem; border-radius: 12px; width: 100%; max-width: 400px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.5); }\n        h1 { font-size: 1.25rem; margin-top: 0; color: var(--text); }\n        .display-area { background: var(--s2); padding: 1rem; border-radius: 8px; border: 1px solid var(--border); margin: 1.5rem 0; text-align: center; font-family: monospace; font-size: 1.5rem; word-break: break-all; min-height: 2rem; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.2s; }\n        .display-area:hover { border-color: var(--accent); }\n        .controls { display: flex; flex-direction: column; gap: 1rem; }\n        .control-row { display: flex; justify-content: space-between; align-items: center; }\n        input[type=\"range\"] { width: 100%; margin: 10px 0; }\n        button { background: var(--accent); color: white; border: none; padding: 0.75rem; border-radius: 6px; font-weight: 600; cursor: pointer; transition: 0.15s; }\n        button:hover { background: var(--accent-h); }\n        .checkbox-group { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }\n        label { font-size: 0.875rem; color: var(--muted); cursor: pointer; }\n        .hint { font-size: 0.75rem; color: var(--muted); text-align: center; margin-top: 1rem; }\n    </style>\n</head>\n<body>\n\n<div class=\"card\">\n    <h1>Password Generator</h1>\n    <div id=\"passwordDisplay\" class=\"display-area\" onclick=\"copyPassword()\">Click to generate</div>\n    \n    <div class=\"controls\">\n        <label>Length: <span id=\"lenVal\">16</span></label>\n        <input type=\"range\" id=\"length\" min=\"4\" max=\"64\" value=\"16\" oninput=\"updateLen()\">\n        \n        <div class=\"checkbox-group\">\n            <label><input type=\"checkbox\" id=\"upper\" checked> A-Z</label>\n            <label><input type=\"checkbox\" id=\"lower\" checked> a-z</label>\n            <label><input type=\"checkbox\" id=\"numbers\" checked> 0-9</label>\n            <label><input type=\"checkbox\" id=\"symbols\" checked> !@#</label>\n        </div>\n        \n        <button onclick=\"generate()\">Generate Password</button>\n    </div>\n    <div class=\"hint\" id=\"status\">Click password to copy to clipboard</div>\n</div>\n\n<footer style=\"text-align:center;padding:16px;color:var(--muted);font-size:12px;opacity:0.8;display:flex;justify-content:center;align-items:center;gap:6px\"><span>Built with</span> <img src=\"https://forge-app.vercel.app/logo.png\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> <a href=\"https://forge-app.vercel.app\" style=\"color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:0.05em\">FORGE</a></footer>\n\n<script>\n    const KEY = 'forge-passgen-v1';\n    \n    const load = () => JSON.parse(localStorage.getItem(KEY)) || { len: 16, upper: true, lower: true, numbers: true, symbols: true };\n    const save = (d) => localStorage.setItem(KEY, JSON.stringify(d));\n\n    const init = () => {\n        const config = load();\n        document.getElementById('length').value = config.len;\n        document.getElementById('lenVal').innerText = config.len;\n        document.getElementById('upper').checked = config.upper;\n        document.getElementById('lower').checked = config.lower;\n        document.getElementById('numbers').checked = config.numbers;\n        document.getElementById('symbols').checked = config.symbols;\n        generate();\n    };\n\n    function updateLen() {\n        const len = document.getElementById('length').value;\n        document.getElementById('lenVal').innerText = len;\n        saveConfig();\n    }\n\n    function saveConfig() {\n        save({\n            len: document.getElementById('length').value,\n            upper: document.getElementById('upper').checked,\n            lower: document.getElementById('lower').checked,\n            numbers: document.getElementById('numbers').checked,\n            symbols: document.getElementById('symbols').checked\n        });\n    }\n\n    function generate() {\n        saveConfig();\n        const len = document.getElementById('length').value;\n        const useUpper = document.getElementById('upper').checked;\n        const useLower = document.getElementById('lower').checked;\n        const useNums = document.getElementById('numbers').checked;\n        const useSyms = document.getElementById('symbols').checked;\n\n        let charset = \"\";\n        if (useUpper) charset += \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\";\n        if (useLower) charset += \"abcdefghijklmnopqrstuvwxyz\";\n        if (useNums) charset += \"0123456789\";\n        if (useSyms) charset += \"!@#$%^&*()_+~`|}{[]:;?><,./-=\";\n\n        if (!charset) {\n            document.getElementById('passwordDisplay').innerText = \"Select an option\";\n            return;\n        }\n\n        let password = \"\";\n        const array = new Uint32Array(len);\n        window.crypto.getRandomValues(array);\n        for (let i = 0; i < len; i++) {\n            password += charset[array[i] % charset.length];\n        }\n        document.getElementById('passwordDisplay').innerText = password;\n        document.getElementById('status').innerText = \"Click password to copy to clipboard\";\n    }\n\n    function copyPassword() {\n        const p = document.getElementById('passwordDisplay').innerText;\n        navigator.clipboard.writeText(p).then(() => {\n            document.getElementById('status').innerText = \"Copied!\";\n            setTimeout(() => document.getElementById('status').innerText = \"Click password to copy to clipboard\", 2000);\n        });\n    }\n\n    window.onload = init;\n</script>\n</body>\n</html>",
