  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Recipe Book</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --bg:#0a0a0a; --s1:#111111; --s2:#1a1a1a; --s3:#242424; --border:#1e293b;\n            --text:#f1f5f9; --muted:#64748b; --accent:#3b82f6; --accent-h:#2563eb;\n            --danger:#ef4444; --success:#22c55e;\n        }\n        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; }\n        .container { max-width: 600px; margin: 0 auto; }\n        .card { background: var(--s1); border: 1px solid var(--border); padding: 20px; border-radius: 8px; margin-bottom: 20px; }\n        h1, h2 { margin-top: 0; }\n        input, textarea { width: 100%; box-sizing: border-box; background: var(--s2); border: 1px solid var(--border); color: var(--text); padding: 10px; border-radius: 4px; margin-bottom: 10px; }\n        button { cursor: pointer; border: none; padding: 10px 16px; border-radius: 4px; background: var(--accent); color: white; font-weight: 600; }\n        button:hover { background: var(--accent-h); }\n        .recipe-item { border-bottom: 1px solid var(--border); padding: 15px 0; }\n        .recipe-item:last-child { border: none; }\n        .delete-btn { background: var(--danger); font-size: 12px; margin-top: 10px; }\n        .search-bar { margin-bottom: 20px; }\n        .empty { color: var(--muted); text-align: center; padding: 40px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Recipe Book</h1>\n        <div class=\"card\">\n            <input type=\"text\" id=\"recipeName\" placeholder=\"Recipe Name\">\n            <textarea id=\"recipeIngredients\" rows=\"3\" placeholder=\"Ingredients (one per line)\"></textarea>\n            <textarea id=\"recipeSteps\" rows=\"3\" placeholder=\"Steps\"></textarea>\n            <button onclick=\"addRecipe()\">Add Recipe</button>\n        </div>\n\n        <input type=\"text\" id=\"search\" class=\"search-bar\" placeholder=\"Search recipes...\" oninput=\"render()\">\n\n        <div id=\"recipeList\"></div>\n    </div>\n\n    <footer style=\"text-align:center;padding:16px;color:var(--muted);font-size:12px;opacity:0.8;display:flex;justify-content:center;align-items:center;gap:6px\"><span>Built with</span> <img src=\"https://forge-app.vercel.app/logo.png\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> <a href=\"https://forge-app.vercel.app\" style=\"color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:0.05em\">FORGE</a></footer>\n\n    <script>\n        const KEY = 'forge-recipebook-v1';\n        let recipes = JSON.parse(localStorage.getItem(KEY) || '[]');\n\n        function save() { localStorage.setItem(KEY, JSON.stringify(recipes)); render(); }\n\n        function addRecipe() {\n            const name = document.getElementById('recipeName').value;\n            const ingredients = document.getElementById('recipeIngredients').value;\n            const steps = document.getElementById('recipeSteps').value;\n            if(!name) return;\n            recipes.push({ id: Date.now(), name, ingredients, steps });\n            document.getElementById('recipeName').value = '';\n            document.getElementById('recipeIngredients').value = '';\n            document.getElementById('recipeSteps').value = '';\n            save();\n        }\n\n        function deleteRecipe(id) {\n            recipes = recipes.filter(r => r.id !== id);\n            save();\n        }\n\n        function render() {\n            const list = document.getElementById('recipeList');\n            const search = document.getElementById('search').value.toLowerCase();\n            const filtered = recipes.filter(r => r.name.toLowerCase().includes(search));\n            \n            if (filtered.length === 0) {\n                list.innerHTML = '<div class=\"empty\">No recipes found.</div>';\n                return;\n            }\n\n            list.innerHTML = filtered.map(r => `\n                <div class=\"card recipe-item\">\n                    <h3>${r.name}</h3>\n                    <strong>Ingredients:</strong><p style=\"white-space:pre-wrap; font-size: 14px; color: var(--muted)\">${r.ingredients}</p>\n                    <strong>Steps:</strong><p style=\"white-space:pre-wrap; font-size: 14px; color: var(--muted)\">${r.steps}</p>\n                    <button class=\"delete-btn\" onclick=\"deleteRecipe(${r.id})\">Delete</button>\n                </div>\n            `).join('');\n        }\n\n        render();\n    </script>\n</body>\n</html>",
