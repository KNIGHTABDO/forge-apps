      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"referrer\" content=\"no-referrer\">\n    <title>Canvas - The Tactile Studio</title>\n    <script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&family=Manrope:wght@500;600;700;800&display=swap\" rel=\"stylesheet\"/>\n    <link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap\" rel=\"stylesheet\"/>\n    <script src=\"/forge.js\"></script>\n    <script>\n        tailwind.config = {\n            theme: {\n                extend: {\n                    colors: {\n                        \"primary\": \"#0058bc\",\n                        \"background\": \"#f7f5ff\",\n                        \"on-surface\": \"#242c51\",\n                        \"on-surface-variant\": \"#515981\",\n                        \"surface-container-lowest\": \"#ffffff\",\n                        \"surface-container\": \"#e4e7ff\",\n                        \"primary-fixed\": \"#6d9fff\",\n                        \"on-primary-fixed\": \"#000000\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Plus Jakarta Sans\"],\n                        \"body\": [\"Be Vietnam Pro\"],\n                        \"label\": [\"Manrope\"]\n                    }\n                }\n            }\n        }\n    </script>\n    <style>\n        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }\n        body { font-family: 'Be Vietnam Pro', sans-serif; background-color: #f7f5ff; color: #242c51; min-height: 100dvh; display: flex; flex-direction: column; overflow: hidden; }\n        #drawing-canvas { touch-action: none; background-color: white; }\n    </style>\n</head>\n<body class=\"pb-32\">\n    <header class=\"fixed top-0 w-full z-50 bg-white/80 backdrop-blur-xl flex justify-between items-center px-6 py-4 shadow-xl shadow-blue-900/5\">\n        <div class=\"flex items-center gap-4\">\n            <h1 class=\"font-headline font-extrabold text-xl bg-gradient-to-r from-blue-700 to-blue-400 bg-clip-text text-transparent\">Canvas Studio</h1>\n        </div>\n        <div class=\"flex gap-2\">\n            <button onclick=\"clearCanvas()\" class=\"text-on-surface-variant hover:text-red-500 font-bold px-3 py-1 rounded-full hover:bg-red-50 transition-all active:scale-95 flex items-center gap-1 text-sm\">\n                <span class=\"material-symbols-outlined text-lg\">delete</span> Clear\n            </button>\n            <button onclick=\"saveCanvas()\" class=\"bg-primary text-white font-bold px-4 py-1.5 rounded-full hover:bg-blue-700 transition-all active:scale-95 shadow-md flex items-center gap-1 text-sm\">\n                <span class=\"material-symbols-outlined text-lg\">save</span> Save to Gallery\n            </button>\n        </div>\n    </header>\n\n    <main class=\"pt-20 px-4 md:px-8 max-w-7xl mx-auto flex-grow w-full flex flex-col h-full\">\n        <!-- Toolbar -->\n        <div class=\"bg-white rounded-2xl shadow-sm p-3 mb-4 flex flex-wrap items-center justify-between gap-4 border border-surface-container\">\n            <div class=\"flex items-center gap-3\">\n                <span class=\"font-label text-sm font-bold text-on-surface-variant uppercase\">Color</span>\n                <div class=\"flex gap-2\" id=\"color-palette\">\n                    <button class=\"w-8 h-8 rounded-full bg-black ring-2 ring-offset-2 ring-primary transition-all color-btn\" data-color=\"#000000\"></button>\n                    <button class=\"w-8 h-8 rounded-full bg-red-500 ring-2 ring-offset-2 ring-transparent transition-all color-btn\" data-color=\"#ef4444\"></button>\n                    <button class=\"w-8 h-8 rounded-full bg-blue-500 ring-2 ring-offset-2 ring-transparent transition-all color-btn\" data-color=\"#3b82f6\"></button>\n                    <button class=\"w-8 h-8 rounded-full bg-green-500 ring-2 ring-offset-2 ring-transparent transition-all color-btn\" data-color=\"#22c55e\"></button>\n                    <button class=\"w-8 h-8 rounded-full bg-yellow-400 ring-2 ring-offset-2 ring-transparent transition-all color-btn\" data-color=\"#facc15\"></button>\n                    <button class=\"w-8 h-8 rounded-full bg-white border-2 border-gray-200 ring-2 ring-offset-2 ring-transparent transition-all color-btn\" data-color=\"#ffffff\" title=\"Eraser\"></button>\n                </div>\n            </div>\n            <div class=\"flex items-center gap-3 w-full md:w-auto\">\n                <span class=\"material-symbols-outlined text-on-surface-variant text-sm\">brush</span>\n                <input type=\"range\" id=\"brush-size\" min=\"1\" max=\"50\" value=\"5\" class=\"w-full md:w-32 accent-primary\">\n                <span id=\"brush-size-val\" class=\"font-label text-xs font-bold w-6\">5px</span>\n            </div>\n        </div>\n\n        <!-- Canvas Container -->\n        <div class=\"flex-grow rounded-2xl overflow-hidden shadow-lg border border-surface-container relative bg-white\" id=\"canvas-container\">\n            <canvas id=\"drawing-canvas\"></canvas>\n        </div>\n    </main>\n\n    <nav class=\"fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-6 pt-3 bg-[#efefff] rounded-t-[2.5rem] z-50 shadow-[0_-10px_40px_rgba(36,44,81,0.06)]\">\n        <a href=\"canvas.html\" class=\"flex flex-col items-center justify-center text-blue-700 bg-white rounded-2xl px-6 py-2 shadow-sm\"><span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">brush</span><span class=\"text-[11px] uppercase mt-1\">Canvas</span></a>\n        <a href=\"index.html\" class=\"flex flex-col items-center justify-center text-slate-400 p-2 hover:text-primary transition-colors\"><span class=\"material-symbols-outlined\">grid_view</span><span class=\"text-[11px] uppercase mt-1\">Gallery</span></a>\n        <a href=\"settings.html\" class=\"flex flex-col items-center justify-center text-slate-400 p-2 hover:text-primary transition-colors\"><span class=\"material-symbols-outlined\">settings</span><span class=\"text-[11px] uppercase mt-1\">Settings</span></a>\n    </nav>\n\n    <script>\n        const canvas = document.getElementById('drawing-canvas');\n        const ctx = canvas.getContext('2d');\n        const container = document.getElementById('canvas-container');\n        \n        let isDrawing = false;\n        let brushColor = '#000000';\n        let brushSize = 5;\n\n        // Resize canvas to fit container\n        function resizeCanvas() {\n            const rect = container.getBoundingClientRect();\n            // Store current drawing\n            const tempCanvas = document.createElement('canvas');\n            const tempCtx = tempCanvas.getContext('2d');\n            tempCanvas.width = canvas.width || rect.width;\n            tempCanvas.height = canvas.height || rect.height;\n            if(canvas.width) tempCtx.drawImage(canvas, 0, 0);\n\n            canvas.width = rect.width;\n            canvas.height = rect.height;\n\n            // Fill with white background\n            ctx.fillStyle = '#ffffff';\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n            \n            // Restore drawing\n            if(tempCanvas.width) ctx.drawImage(tempCanvas, 0, 0);\n\n            setupContext();\n        }\n\n        function setupContext() {\n            ctx.lineJoin = 'round';\n            ctx.lineCap = 'round';\n            ctx.strokeStyle = brushColor;\n            ctx.lineWidth = brushSize;\n        }\n\n        window.addEventListener('resize', resizeCanvas);\n        // Initial setup\n        setTimeout(resizeCanvas, 100);\n\n        // Drawing events\n        function startDrawing(e) {\n            isDrawing = true;\n            draw(e);\n        }\n\n        function stopDrawing() {\n            isDrawing = false;\n            ctx.beginPath();\n        }\n\n        function draw(e) {\n            if (!isDrawing) return;\n            e.preventDefault();\n\n            const rect = canvas.getBoundingClientRect();\n            let x, y;\n\n            if (e.type.includes('mouse')) {\n                x = e.clientX - rect.left;\n                y = e.clientY - rect.top;\n            } else if (e.type.includes('touch')) {\n                x = e.touches[0].clientX - rect.left;\n                y = e.touches[0].clientY - rect.top;\n            }\n\n            ctx.lineTo(x, y);\n            ctx.stroke();\n            ctx.beginPath();\n            ctx.moveTo(x, y);\n        }\n\n        canvas.addEventListener('mousedown', startDrawing);\n        canvas.addEventListener('mousemove', draw);\n        canvas.addEventListener('mouseup', stopDrawing);\n        canvas.addEventListener('mouseout', stopDrawing);\n\n        canvas.addEventListener('touchstart', startDrawing, { passive: false });\n        canvas.addEventListener('touchmove', draw, { passive: false });\n        canvas.addEventListener('touchend', stopDrawing);\n\n        // Toolbar Logic\n        const colorBtns = document.querySelectorAll('.color-btn');\n        colorBtns.forEach(btn => {\n            btn.addEventListener('click', (e) => {\n                colorBtns.forEach(b => b.classList.replace('ring-primary', 'ring-transparent'));\n                e.target.classList.replace('ring-transparent', 'ring-primary');\n                brushColor = e.target.dataset.color;\n                ctx.strokeStyle = brushColor;\n            });\n        });\n\n        const sizeInput = document.getElementById('brush-size');\n        const sizeVal = document.getElementById('brush-size-val');\n        sizeInput.addEventListener('input', (e) => {\n            brushSize = e.target.value;\n            sizeVal.textContent = brushSize + 'px';\n            ctx.lineWidth = brushSize;\n        });\n\n        function clearCanvas() {\n            if(confirm('Are you sure you want to clear the canvas?')) {\n                ctx.fillStyle = '#ffffff';\n                ctx.fillRect(0, 0, canvas.width, canvas.height);\n            }\n        }\n\n        async function saveCanvas() {\n            try {\n                const dataURL = canvas.toDataURL('image/png');\n                let sketches = await window.forge.db.get('tactile_studio', 'default') || [];\n                \n                const newSketch = {\n                    id: Date.now(),\n                    title: \"Sketch \" + (sketches.length + 1),\n                    date: new Date().toLocaleDateString(),\n                    src: dataURL\n                };\n                \n                sketches.push(newSketch);\n                await window.forge.db.set('tactile_studio', 'default', sketches);\n                \n                alert(\"Saved to Gallery!\");\n                window.location.href = 'index.html';\n            } catch (err) {\n                console.error(\"Error saving canvas:\", err);\n                alert(\"Failed to save sketch.\");\n            }\n        }\n    </script>\n</body>\n</html>"
    },
    {
      "path": "settings.html",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"referrer\" content=\"no-referrer\">\n    <title>Settings - The Tactile Studio</title>\n    <script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&family=Manrope:wght@500;600;700;800&display=swap\" rel=\"stylesheet\"/>\n    <link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap\" rel=\"stylesheet\"/>\n    <script src=\"/forge.js\"></script>\n    <script>\n        tailwind.config = {\n            theme: {\n                extend: {\n                    colors: {\n                        \"primary\": \"#0058bc\",\n                        \"background\": \"#f7f5ff\",\n                        \"on-surface\": \"#242c51\",\n                        \"on-surface-variant\": \"#515981\",\n                        \"surface-container-lowest\": \"#ffffff\",\n                        \"surface-container\": \"#e4e7ff\",\n                        \"primary-fixed\": \"#6d9fff\",\n                        \"on-primary-fixed\": \"#000000\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Plus Jakarta Sans\"],\n                        \"body\": [\"Be Vietnam Pro\"],\n                        \"label\": [\"Manrope\"]\n                    }\n                }\n            }\n        }\n    </script>\n    <style>\n        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }\n        body { font-family: 'Be Vietnam Pro', sans-serif; background-color: #f7f5ff; color: #242c51; min-height: 100dvh; display: flex; flex-direction: column; }\n    </style>\n</head>\n<body class=\"pb-32\">\n    <header class=\"fixed top-0 w-full z-50 bg-white/80 backdrop-blur-xl flex justify-between items-center px-6 py-4 shadow-xl shadow-blue-900/5\">\n        <div class=\"flex items-center gap-4\">\n            <h1 class=\"font-headline font-extrabold text-xl bg-gradient-to-r from-blue-700 to-blue-400 bg-clip-text text-transparent\">Settings</h1>\n        </div>\n    </header>\n\n    <main class=\"pt-24 px-6 md:px-12 max-w-3xl mx-auto flex-grow w-full\">\n        <div class=\"bg-white rounded-2xl shadow-sm border border-surface-container p-6 md:p-8 mb-8\">\n            <h2 class=\"font-headline text-2xl font-extrabold text-on-surface mb-6\">Data Management</h2>\n            \n            <div class=\"flex flex-col sm:flex-row items-start sm:items-center justify-between p-4 bg-red-50 rounded-xl border border-red-100\">\n                <div class=\"mb-4 sm:mb-0\">\n                    <h3 class=\"font-bold text-red-900\">Erase All Data</h3>\n                    <p class=\"text-sm text-red-700 mt-1\">Permanently delete all sketches from your gallery. This action cannot be undone.</p>\n                </div>\n                <button onclick=\"clearAllData()\" class=\"px-6 py-2 bg-red-600 text-white font-bold rounded-lg shadow-sm hover:bg-red-700 transition-colors whitespace-nowrap\">\n                    Delete All\n                </button>\n            </div>\n        </div>\n\n        <div class=\"bg-white rounded-2xl shadow-sm border border-surface-container p-6 md:p-8\">\n            <h2 class=\"font-headline text-2xl font-extrabold text-on-surface mb-6\">App Info</h2>\n            <div class=\"space-y-4\">\n                <div class=\"flex justify-between items-center py-3 border-b border-gray-100\">\n                    <span class=\"font-semibold text-on-surface-variant\">Version</span>\n                    <span class=\"text-slate-500\">1.0.0</span>\n                </div>\n                <div class=\"flex justify-between items-center py-3 border-b border-gray-100\">\n                    <span class=\"font-semibold text-on-surface-variant\">Storage</span>\n                    <span class=\"text-slate-500\">Local DB Indexed</span>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    <nav class=\"fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-6 pt-3 bg-[#efefff] rounded-t-[2.5rem] z-50 shadow-[0_-10px_40px_rgba(36,44,81,0.06)]\">\n        <a href=\"canvas.html\" class=\"flex flex-col items-center justify-center text-slate-400 p-2 hover:text-primary transition-colors\"><span class=\"material-symbols-outlined\">brush</span><span class=\"text-[11px] uppercase mt-1\">Canvas</span></a>\n        <a href=\"index.html\" class=\"flex flex-col items-center justify-center text-slate-400 p-2 hover:text-primary transition-colors\"><span class=\"material-symbols-outlined\">grid_view</span><span class=\"text-[11px] uppercase mt-1\">Gallery</span></a>\n        <a href=\"settings.html\" class=\"flex flex-col items-center justify-center text-blue-700 bg-white rounded-2xl px-6 py-2 shadow-sm\"><span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">settings</span><span class=\"text-[11px] uppercase mt-1\">Settings</span></a>\n    </nav>\n\n    <footer class=\"text-center p-4 text-neutral-400 text-xs opacity-80 flex justify-center items-center gap-1.5 mt-auto\"><span>Built with</span> <img src=\"https://forge-app.vercel.app/logo.png\" alt=\"Forge\" class=\"w-3.5 h-3.5 rounded-sm object-cover\"> <a href=\"https://forge-app.vercel.app\" class=\"text-blue-500 font-semibold tracking-wide no-underline\">FORGE</a></footer>\n\n    <script>\n        async function clearAllData() {\n            if(confirm(\"Are you absolutely sure you want to delete all sketches? This cannot be undone.\")) {\n                try {\n                    await window.forge.db.set('tactile_studio', 'default', []);\n                    alert(\"All data cleared.\");\n                } catch(e) {\n                    alert(\"Error clearing data.\");\n                }\n            }\n        }\n    </script>\n</body>\n</html>"
    }
