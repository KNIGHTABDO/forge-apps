  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Modern Kanban Board</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');\n\n        :root {\n            --bg:#0a0a0a; --s1:#111111; --s2:#1a1a1a; --s3:#242424; --border:#1e293b;\n            --text:#f1f5f9; --muted:#64748b; --accent:#3b82f6; --accent-h:#2563eb;\n            --danger:#ef4444; --success:#22c55e;\n        }\n\n        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; min-height: 100vh; }\n        \n        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }\n        \n        .board { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; align-items: start; }\n        \n        .column { background: var(--s1); border: 1px solid var(--border); border-radius: 12px; padding: 16px; min-height: 400px; display: flex; flex-direction: column; gap: 12px; }\n        .column h2 { font-size: 14px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 10px 0; }\n\n        .card { background: var(--s2); padding: 16px; border-radius: 8px; border: 1px solid var(--border); cursor: grab; transition: all 0.2s ease; position: relative; }\n        .card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3); }\n        .card button { position: absolute; top: 8px; right: 8px; background: none; border: none; color: var(--muted); cursor: pointer; }\n        .card button:hover { color: var(--danger); }\n\n        .btn { background: var(--accent); color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-weight: 500; }\n        .btn:hover { background: var(--accent-h); }\n\n        .modal { position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(4px); display: none; align-items: center; justify-content: center; }\n        .modal-content { background: var(--s2); padding: 24px; border-radius: 12px; border: 1px solid var(--border); width: 300px; display: flex; flex-direction: column; gap: 12px; }\n        input { background: var(--s1); border: 1px solid var(--border); color: white; padding: 10px; border-radius: 6px; }\n    </style>\n</head>\n<body>\n\n    <header>\n        <h1>Kanban Board</h1>\n        <button class=\"btn\" onclick=\"openModal()\"><i data-lucide=\"plus\"></i> Add Task</button>\n    </header>\n\n    <div class=\"board\" id=\"board\">\n        <div class=\"column\" data-status=\"todo\" ondrop=\"drop(event)\" ondragover=\"allowDrop(event)\">\n            <h2>To Do</h2>\n            <div class=\"cards-container\"></div>\n        </div>\n        <div class=\"column\" data-status=\"progress\" ondrop=\"drop(event)\" ondragover=\"allowDrop(event)\">\n            <h2>In Progress</h2>\n            <div class=\"cards-container\"></div>\n        </div>\n        <div class=\"column\" data-status=\"done\" ondrop=\"drop(event)\" ondragover=\"allowDrop(event)\">\n            <h2>Done</h2>\n            <div class=\"cards-container\"></div>\n        </div>\n    </div>\n\n    <div class=\"modal\" id=\"modal\">\n        <div class=\"modal-content\">\n            <input type=\"text\" id=\"taskInput\" placeholder=\"Task name...\">\n            <button class=\"btn\" onclick=\"addTask()\">Save Task</button>\n        </div>\n    </div>\n\n    <footer style=\"margin-top:40px\"><span>Built with</span> <img src=\"https://forge-app.vercel.app/logo.png\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> <a href=\"https://forge-app.vercel.app\" style=\"color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:0.05em\">FORGE</a></footer>\n\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <script>\n        const KEY = 'forge-kanban-v1';\n        let tasks = JSON.parse(localStorage.getItem(KEY)) || [];\n\n        function save() { localStorage.setItem(KEY, JSON.stringify(tasks)); render(); }\n\n        function render() {\n            document.querySelectorAll('.cards-container').forEach(c => c.innerHTML = '');\n            tasks.forEach((t, i) => {\n                const col = document.querySelector(`.column[data-status=\"${t.status}\"] .cards-container`);\n                const el = document.createElement('div');\n                el.className = 'card';\n                el.draggable = true;\n                el.id = `task-${i}`;\n                el.ondragstart = (e) => e.dataTransfer.setData('text', i);\n                el.innerHTML = `${t.text}<button onclick=\"deleteTask(${i})\"><i data-lucide=\"trash-2\" size=\"14\"></i></button>`;\n                col.appendChild(el);\n            });\n            lucide.createIcons();\n        }\n\n        function openModal() { document.getElementById('modal').style.display = 'flex'; }\n        function addTask() {\n            const val = document.getElementById('taskInput').value;\n            if(!val) return;\n            tasks.push({ text: val, status: 'todo' });\n            document.getElementById('taskInput').value = '';\n            document.getElementById('modal').style.display = 'none';\n            save();\n        }\n\n        function deleteTask(i) { tasks.splice(i, 1); save(); }\n\n        function allowDrop(e) { e.preventDefault(); }\n        function drop(e) {\n            e.preventDefault();\n            const id = e.dataTransfer.getData('text');\n            const status = e.target.closest('.column').dataset.status;\n            tasks[id].status = status;\n            save();\n        }\n\n        window.onclick = (e) => { if(e.target.id === 'modal') e.target.style.display = 'none'; }\n        \n        document.addEventListener('DOMContentLoaded', () => { render(); lucide.createIcons(); });\n    </script>\n</body>\n</html>",
