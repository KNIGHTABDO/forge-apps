>Community support</span>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <i data-lucide=\"x\" class=\"w-5 h-5 text-neutral-600 flex-shrink-0 mt-0.5\"></i>\n                            <span class=\"text-neutral-600\">Advanced analytics</span>\n                        </li>\n                    </ul>\n                </div>\n\n                <!-- Professional Plan -->\n                <div class=\"p-8 border border-blue-600 rounded-xl bg-blue-600/5 relative flex flex-col transform md:scale-105\">\n                    <div class=\"absolute -top-4 left-1/2 transform -translate-x-1/2 bg-blue-600 text-white px-4 py-1 rounded-full text-sm font-semibold\">\n                        Popular\n                    </div>\n                    <h3 class=\"text-2xl font-bold mb-2\">Professional</h3>\n                    <p class=\"text-neutral-400 text-sm mb-6\">For growing teams</p>\n                    <div class=\"mb-8\">\n                        <span class=\"text-5xl font-bold\">$99</span>\n                        <span class=\"text-neutral-400 ml-2\">/month</span>\n                    </div>\n                    <button class=\"w-full py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-colors duration-200 mb-8\">\n                        Get Started\n                    </button>\n                    <ul class=\"space-y-4 text-sm flex-1\">\n                        <li class=\"flex items-start gap-3\">\n                            <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500 flex-shrink-0 mt-0.5\"></i>\n                            <span>Unlimited requests</span>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500 flex-shrink-0 mt-0.5\"></i>\n                            <span>100 GB storage</span>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500 flex-shrink-0 mt-0.5\"></i>\n                            <span>Email support</span>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500 flex-shrink-0 mt-0.5\"></i>\n                            <span>Advanced analytics</span>\n                        </li>\n                    </ul>\n                </div>\n\n                <!-- Enterprise Plan -->\n                <div class=\"p-8 border border-neutral-800 rounded-xl hover:border-neutral-700 transition-all duration-200 flex flex-col\">\n                    <h3 class=\"text-2xl font-bold mb-2\">Enterprise</h3>\n                    <p class=\"text-neutral-400 text-sm mb-6\">For large organizations</p>\n                    <div class=\"mb-8\">\n                        <span class=\"text-5xl font-bold\">Custom</span>\n                    </div>\n                    <button class=\"w-full py-3 border border-neutral-700 text-neutral-100 font-semibold rounded-lg hover:border-neutral-600 hover:bg-neutral-900/50 transition-colors duration-200 mb-8\">\n                        Contact Sales\n                    </button>\n                    <ul class=\"space-y-4 text-sm flex-1\">\n                        <li class=\"flex items-start gap-3\">\n                            <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500 flex-shrink-0 mt-0.5\"></i>\n                            <span>Unlimited everything</span>\n                        </li>\n                        <li class=\"flex items-start gap-3\">\n                            <i data-lucide=\"check\" class=\"w-5 h-5 text-green-500 flex-shrink-0 mt-0.5\"></i>\n                            <span>Dedicated account manager</span>\n                        </li>\n                        <li class=\"flex items-s