  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>FORGE Calculator</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');\n        :root {\n            --bg:#0a0a0a; --s1:#111111; --s2:#1a1a1a; --s3:#242424; --border:#1e293b;\n            --text:#f1f5f9; --muted:#64748b; --accent:#3b82f6; --accent-h:#2563eb;\n            --danger:#ef4444; --success:#22c55e; --warning:#f59e0b;\n        }\n        [data-theme='light'] {\n            --bg:#f8fafc; --s1:#ffffff; --s2:#f1f5f9; --s3:#e2e8f0; --border:#cbd5e1;\n            --text:#0f172a; --muted:#64748b; --accent:#3b82f6; --accent-h:#2563eb;\n        }\n        body {\n            font-family: 'Inter', system-ui, sans-serif;\n            background-color: var(--bg);\n            color: var(--text);\n            margin: 0;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            min-height: 100vh;\n            padding: 20px;\n            transition: background 0.3s, color 0.3s;\n        }\n        .calc-container {\n            background: var(--s1);\n            border: 1px solid var(--border);\n            padding: 20px;\n            border-radius: 12px;\n            width: 100%;\n            max-width: 320px;\n            transition: background 0.3s, border 0.3s;\n        }\n        #display {\n            width: 100%;\n            height: 60px;\n            background: var(--s2);\n            border: 1px solid var(--border);\n            color: var(--text);\n            font-size: 24px;\n            text-align: right;\n            padding: 10px;\n            margin-bottom: 20px;\n            border-radius: 8px;\n            box-sizing: border-box;\n            overflow: hidden;\n        }\n        .buttons {\n            display: grid;\n            grid-template-columns: repeat(4, 1fr);\n            gap: 10px;\n        }\n        button {\n            padding: 15px;\n            background: var(--s3);\n            border: none;\n            color: var(--text);\n            border-radius: 8px;\n            cursor: pointer;\n            font-weight: 600;\n            transition: background 0.15s;\n        }\n        button:hover { background: var(--border); }\n        button.op { background: var(--accent); color: white; }\n        button.op:hover { background: var(--accent-h); }\n        button.span-2 { grid-column: span 2; }\n        .theme-toggle {\n            margin-bottom: 20px;\n            background: var(--s2);\n            border: 1px solid var(--border);\n            padding: 8px 16px;\n            cursor: pointer;\n            border-radius: 20px;\n            color: var(--text);\n        }\n    </style>\n</head>\n<body>\n\n<button class=\"theme-toggle\" onclick=\"toggleTheme()\">Toggle Theme</button>\n\n<div class=\"calc-container\">\n    <div id=\"display\">0</div>\n    <div class=\"buttons\">\n        <button onclick=\"clearCalc()\">C</button>\n        <button onclick=\"append('(')\">(</button>\n        <button onclick=\"append(')')\">)</button>\n        <button class=\"op\" onclick=\"append('/')\">/</button>\n        <button onclick=\"append('7')\">7</button>\n        <button onclick=\"append('8')\">8</button>\n        <button onclick=\"append('9')\">9</button>\n        <button class=\"op\" onclick=\"append('*')\">×</button>\n        <button onclick=\"append('4')\">4</button>\n        <button onclick=\"append('5')\">5</button>\n        <button onclick=\"append('6')\">6</button>\n        <button class=\"op\" onclick=\"append('-')\">-</button>\n        <button onclick=\"append('1')\">1</button>\n        <button onclick=\"append('2')\">2</button>\n        <button onclick=\"append('3')\">3</button>\n        <button class=\"op\" onclick=\"append('+')\">+</button>\n        <button onclick=\"append('0')\">0</button>\n        <button onclick=\"append('.')\">.</button>\n        <button class=\"span-2 op\" onclick=\"calculate()\">=</button>\n    </div>\n</div>\n\n<footer style=\"margin-top:auto;padding:16px;color:var(--muted);font-size:12px;opacity:0.8;display:flex;justify-content:center;align-items:center;gap:6px\">\n    <span>Built with</span> \n    <img src=\"http://localhost:3000/logo.png\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> \n    <a href=\"http://localhost:3000\" style=\"color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:0.05em\">FORGE</a>\n</footer>\n\n<script>\n    const KEY = 'forge-calculator-v1';\n    const THEME_KEY = 'forge-calculator-theme';\n    const display = document.getElementById('display');\n    let current = localStorage.getItem(KEY) || '0';\n    \n    const savedTheme = localStorage.getItem(THEME_KEY) || 'dark';\n    document.documentElement.setAttribute('data-theme', savedTheme);\n\n    function toggleTheme() {\n        const currentTheme = document.documentElement.getAttribute('data-theme');\n        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';\n        document.documentElement.setAttribute('data-theme', newTheme);\n        localStorage.setItem(THEME_KEY, newTheme);\n    }\n\n    display.innerText = current;\n\n    function save() {\n        localStorage.setItem(KEY, current);\n    }\n\n    function updateDisplay() {\n        display.innerText = current;\n        save();\n    }\n\n    function append(val) {\n        if (current === '0' || current === 'Error') current = val;\n        else current += val;\n        updateDisplay();\n    }\n\n    function clearCalc() {\n        current = '0';\n        updateDisplay();\n    }\n\n    function calculate() {\n        try {\n            current = eval(current.replace('×', '*')).toString();\n        } catch (e) {\n            current = 'Error';\n            setTimeout(() => { current = '0'; updateDisplay(); }, 1000);\n        }\n        updateDisplay();\n    }\n</script>\n</body>\n</html>",
