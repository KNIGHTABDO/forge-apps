  "currentHTML": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>FORGE Calculator</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --bg:#0a0a0a; --s1:#111111; --s2:#1a1a1a; --s3:#242424; --border:#1e293b;\n            --text:#f1f5f9; --muted:#64748b; --accent:#3b82f6; --accent-h:#2563eb;\n            --danger:#ef4444; --success:#22c55e; --warning:#f59e0b;\n        }\n        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }\n        .container { width: 100%; max-width: 360px; padding: 20px; box-sizing: border-box; }\n        #display { width: 100%; background: var(--s1); border: 1px solid var(--border); color: var(--text); font-size: 2rem; padding: 20px; margin-bottom: 20px; text-align: right; border-radius: 8px; box-sizing: border-box; outline: none; }\n        .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }\n        button { background: var(--s2); border: 1px solid var(--border); color: var(--text); padding: 20px 0; border-radius: 8px; font-size: 1.2rem; cursor: pointer; transition: 150ms; }\n        button:hover { background: var(--s3); }\n        button.op { background: var(--s3); color: var(--accent); }\n        button.equal { background: var(--accent); color: white; grid-column: span 2; }\n        button.equal:hover { background: var(--accent-h); }\n        button.clear { color: var(--danger); }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <input type=\"text\" id=\"display\" readonly value=\"0\">\n        <div class=\"grid\">\n            <button class=\"clear\" onclick=\"clearDisplay()\">C</button>\n            <button onclick=\"appendToDisplay('(')\">(</button>\n            <button onclick=\"appendToDisplay(')')\">)</button>\n            <button class=\"op\" onclick=\"appendToDisplay('/')\">/</button>\n            <button onclick=\"appendToDisplay('7')\">7</button>\n            <button onclick=\"appendToDisplay('8')\">8</button>\n            <button onclick=\"appendToDisplay('9')\">9</button>\n            <button class=\"op\" onclick=\"appendToDisplay('*')\">*</button>\n            <button onclick=\"appendToDisplay('4')\">4</button>\n            <button onclick=\"appendToDisplay('5')\">5</button>\n            <button onclick=\"appendToDisplay('6')\">6</button>\n            <button class=\"op\" onclick=\"appendToDisplay('-')\">-</button>\n            <button onclick=\"appendToDisplay('1')\">1</button>\n            <button onclick=\"appendToDisplay('2')\">2</button>\n            <button onclick=\"appendToDisplay('3')\">3</button>\n            <button class=\"op\" onclick=\"appendToDisplay('+')\">+</button>\n            <button onclick=\"appendToDisplay('0')\">0</button>\n            <button onclick=\"appendToDisplay('.')\">.</button>\n            <button class=\"equal\" onclick=\"calculate()\">=</button>\n        </div>\n    </div>\n\n    <footer style=\"text-align:center;padding:16px;color:var(--muted);font-size:12px;opacity:0.8;display:flex;justify-content:center;align-items:center;gap:6px\"><span>Built with</span> <img src=\"http://localhost:3000/logo.png\" alt=\"Forge\" style=\"width:14px;height:14px;border-radius:3px;object-fit:cover;\"> <a href=\"http://localhost:3000\" style=\"color:var(--accent);text-decoration:none;font-weight:600;letter-spacing:0.05em\">FORGE</a></footer>\n\n    <script>\n        const display = document.getElementById('display');\n        const KEY = 'forge-calc-v1';\n\n        function appendToDisplay(val) {\n            if (display.value === '0' || display.value === 'Error') display.value = '';\n            display.value += val;\n            saveState();\n        }\n\n        function clearDisplay() {\n            display.value = '0';\n            saveState();\n        }\n\n        function calculate() {\n            try {\n                display.value = eval(display.value);\n            } catch {\n                display.value = 'Error';\n            }\n            saveState();\n        }\n\n        function saveState() {\n            localStorage.setItem(KEY, display.value);\n        }\n\n        window.onload = () => {\n            const saved = localStorage.getItem(KEY);\n            if (saved) display.value = saved;\n        };\n    </script>\n</body>\n</html>",
